page {
  box-sizing: border-box;
  min-height: 100vh;
  background: #f5f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

view,
text {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.muted {
  color: #64748b;
}
