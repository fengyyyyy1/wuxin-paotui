.settings-page{min-height:100vh;padding:30rpx 32rpx 48rpx;background:#f6f7f9}.title,.subtitle{display:block}.title{font-size:44rpx;font-weight:800}.subtitle{margin-top:8rpx;color:#999;font-size:23rpx}.settings-card,.privacy-card{margin-top:28rpx;padding:6rpx 28rpx;background:#fff;border-radius:32rpx}.settings-card>button,.setting-row{display:flex;align-items:center;justify-content:space-between;width:100%;min-height:112rpx;border-bottom:1rpx solid #eee;text-align:left}.settings-card>button::after{border:0}.setting-row{border-bottom:0}.settings-card view text,.privacy-card text{display:block}.settings-card view text:first-child{font-size:26rpx;font-weight:650}.settings-card view text:last-child{margin-top:7rpx;color:#999;font-size:20rpx}.arrow{color:#bbb;font-size:32rpx}.value{color:#18b566;font-size:22rpx}.privacy-card{padding:28rpx}.privacy-card text:first-child{font-size:27rpx;font-weight:700}.privacy-card text:last-child{margin-top:12rpx;color:#666;font-size:22rpx;line-height:1.7}.logout{display:flex;align-items:center;justify-content:center;height:94rpx;margin-top:28rpx;color:#ff4d4f;background:#fff1f1;border-radius:28rpx;font-size:27rpx;font-weight:650}.logout::after{border:0}
