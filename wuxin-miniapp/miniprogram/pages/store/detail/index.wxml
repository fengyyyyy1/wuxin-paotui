<view class="store-page">
  <page-state loading="{{loadingStore}}" error="{{errorMessage}}" empty="{{!loadingStore && !errorMessage && !store}}" empty-title="门店不存在" bind:retry="refreshAll" />
  <block wx:if="{{store}}">
    <view class="hero-card">
      <image class="hero-image" src="{{store.imageUrl}}" mode="aspectFill" binderror="handleStoreImageError" />
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <view class="hero-top"><text class="hero-status {{store.canSell ? 'open' : ''}}">{{store.statusText}}</text><text class="hero-hours">{{store.timeText}}</text></view>
        <text class="store-name">{{store.storeName}}</text>
        <text class="store-description">{{store.storeDescription || '品质商品，安心选购'}}</text>
        <view class="store-meta"><text>{{store.addressText || '地址待补充'}}</text><text>配送费以结算页为准</text></view>
      </view>
    </view>

    <view class="search-card">
      <view class="search-field"><image src="/assets/images/icons/search-line.svg" /><input value="{{keyword}}" placeholder="搜索店内商品" confirm-type="search" bindinput="onKeywordInput" bindconfirm="searchProducts" /><button wx:if="{{keyword}}" bindtap="clearKeyword">×</button></view>
      <button class="search-action" bindtap="searchProducts">搜索</button>
    </view>

    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-row"><button wx:for="{{categories}}" wx:key="categoryId" class="category {{activeCategoryId === item.categoryId ? 'active' : ''}}" data-id="{{item.categoryId === null ? 'all' : item.categoryId}}" bindtap="selectCategory">{{item.categoryName}}</button></view>
    </scroll-view>

    <view class="product-list">
      <view class="product-card" wx:for="{{products}}" wx:key="productId">
        <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" data-id="{{item.productId}}" binderror="handleProductImageError" bindtap="goToProductDetail" />
        <view class="product-content" data-id="{{item.productId}}" bindtap="goToProductDetail">
          <text class="product-name">{{item.productName}}</text>
          <text class="product-description">{{item.productDescription || '品质好物，放心选购'}}</text>
          <view class="product-meta"><text wx:if="{{item.sales !== null && item.sales !== undefined}}">已售 {{item.sales}}</text><text>{{item.stockText}}</text></view>
          <view class="product-bottom">
            <view class="price"><text>¥</text><text class="price-number">{{item.priceText}}</text></view>
            <button wx:if="{{item.cartQuantity === 0}}" class="add-button" disabled="{{!item.canQuickAdd || item.cartOperating}}" data-id="{{item.productId}}" catchtap="quickAddCart">＋</button>
            <view wx:else class="stepper" catchtap="preventPanelMove"><button data-id="{{item.productId}}" catchtap="decreaseCartItem">−</button><text>{{item.cartQuantity}}</text><button class="plus" data-id="{{item.productId}}" catchtap="increaseCartItem">＋</button></view>
          </view>
        </view>
      </view>
    </view>
    <page-state loading="{{loadingProducts && products.length === 0}}" error="{{productErrorMessage}}" empty="{{!loadingProducts && !productErrorMessage && products.length === 0}}" empty-title="{{productEmptyText}}" empty-description="换个分类或关键词试试" bind:retry="refreshProducts" />
    <view wx:if="{{loadingProducts && products.length}}" class="more-text">正在加载更多</view>
  </block>

  <view wx:if="{{store}}" class="bottom-spacer"></view>
  <view wx:if="{{store}}" class="bottom-cart">
    <button class="cart-summary" bindtap="openCartPanel"><view class="cart-icon"><image src="/assets/images/icons/cart-line.svg" /><text wx:if="{{cartCount}}" class="badge">{{cartCount}}</text></view><view class="amount"><text class="amount-price">¥{{cartSelectedTotalAmountText}}</text><text class="amount-caption">已选 {{cartSelectedProductCount}} 件</text></view></button>
    <button class="checkout" disabled="{{!cartSelectedProductCount}}" bindtap="checkout">去结算</button>
  </view>

  <view wx:if="{{cartPanelVisible}}" class="sheet-layer" catchtouchmove="preventPanelMove">
    <view class="sheet-mask" bindtap="closeCartPanel"></view>
    <view class="sheet">
      <view class="sheet-header"><view><text class="sheet-title">{{cartStoreName || store.storeName}}</text><text class="sheet-subtitle">已选 {{cartSelectedProductCount}} 件</text></view><view class="sheet-actions"><button bindtap="clearCurrentCart">清空</button><button class="close" bindtap="closeCartPanel">×</button></view></view>
      <scroll-view class="sheet-list" scroll-y>
        <view class="sheet-item" wx:for="{{cartItems}}" wx:key="productId"><image src="{{item.imageUrl}}" mode="aspectFill" data-id="{{item.productId}}" binderror="handleProductImageError" /><view class="sheet-copy"><text class="sheet-name">{{item.productName}}</text><text wx:if="{{item.cartInvalidReason}}" class="invalid">{{item.cartInvalidReason}}</text><view class="sheet-bottom"><text class="sheet-price">¥{{item.priceText}}</text><view class="stepper"><button data-id="{{item.productId}}" bindtap="decreaseCartItem">−</button><text>{{item.cartQuantity}}</text><button class="plus" data-id="{{item.productId}}" bindtap="increaseCartItem">＋</button></view></view></view></view>
      </scroll-view>
      <view class="sheet-footer"><view><text class="sheet-total-label">合计</text><text class="sheet-total">¥{{cartSelectedTotalAmountText}}</text></view><button class="checkout" disabled="{{!cartSelectedProductCount}}" bindtap="checkout">去结算</button></view>
    </view>
  </view>
</view>
