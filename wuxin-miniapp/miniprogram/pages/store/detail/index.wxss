.store-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx calc(176rpx + env(safe-area-inset-bottom));
  background: #f6f7f9;
}

.store-page view,
.store-page image,
.store-page button,
.store-page input,
.store-page scroll-view {
  box-sizing: border-box;
}

.store-info-card,
.store-intro-card,
.store-filter-card,
.product-card,
.state-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.store-info-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
}

.store-logo {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  background: #eef2f7;
  border-radius: 16rpx;
}

.store-info-main {
  flex: 1;
  min-width: 0;
}

.store-title {
  overflow: hidden;
  color: #1c1c1e;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: normal;
}

.store-meta-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  margin-top: 10rpx;
}

.store-status {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 28rpx;
  white-space: nowrap;
}

.status-open {
  color: #007c16;
  background: #edf7ef;
}

.status-rest {
  color: #666666;
  background: #f2f2f2;
}

.store-time,
.store-address {
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: normal;
}

.store-address {
  margin-top: 8rpx;
}

.store-intro-card,
.store-filter-card {
  margin-top: 24rpx;
  padding: 32rpx;
}

.intro-title {
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.intro-text,
.intro-phone {
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: normal;
}

.intro-text {
  margin-top: 12rpx;
}

.intro-phone {
  margin-top: 6rpx;
}

.store-closed-tip {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  color: #ff6a00;
  background: #fff7ed;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 32rpx;
}

.search-box {
  width: 100%;
  min-width: 0;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 28rpx;
  color: #1c1c1e;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 36rpx;
  font-size: 26rpx;
  line-height: 72rpx;
}

.search-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.filter-button,
.stepper-minus,
.stepper-plus,
.sheet-clear,
.sheet-close,
.sheet-delete,
.checkout-button {
  flex-shrink: 0;
  margin: 0;
  padding: 0;
  border: 0;
  line-height: normal;
}

.filter-button::after,
.stepper-minus::after,
.stepper-plus::after,
.sheet-clear::after,
.sheet-close::after,
.sheet-delete::after,
.checkout-button::after {
  border: 0;
}

.filter-button {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #1c1c1e;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.filter-button-primary {
  color: #ffffff;
  background: #007c16;
  border-color: #007c16;
}

.filter-button[disabled] {
  color: #999999;
  background: #f5f5f5;
  border-color: #eeeeee;
}

.category-scroll {
  width: calc(100% + 64rpx);
  margin: 24rpx -32rpx 0;
  padding-left: 32rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding-right: 32rpx;
}

.category-chip {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  color: #1c1c1e;
  background: #ffffff;
  border: 2rpx solid #eeeeee;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 32rpx;
  white-space: nowrap;
}

.category-chip-active {
  color: #ffffff;
  background: #007c16;
  border-color: #007c16;
}

.product-list {
  margin-top: 24rpx;
}

.product-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.product-image-wrap {
  flex-shrink: 0;
  width: 144rpx;
  height: 144rpx;
}

.product-image {
  display: block;
  width: 144rpx;
  height: 144rpx;
  background: #f1f3f5;
  border-radius: 16rpx;
}

.product-main {
  display: flex;
  flex: 1;
  min-width: 0;
  min-height: 144rpx;
  flex-direction: column;
}

.product-name {
  display: -webkit-box;
  overflow: hidden;
  color: #1c1c1e;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 38rpx;
  word-break: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.product-description {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 32rpx;
  word-break: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.product-meta {
  margin-top: 6rpx;
}

.product-stock {
  color: #666666;
  font-size: 22rpx;
  line-height: 30rpx;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
  margin-top: auto;
  padding-top: 10rpx;
}

.product-price,
.sheet-price,
.item-price {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #ff6a00;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-mark {
  font-size: 24rpx;
  font-weight: 800;
}

.cart-stepper {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  min-width: 184rpx;
  height: 72rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #edf2f7;
  border-radius: 36rpx;
  white-space: nowrap;
}

.cart-stepper-single {
  min-width: 72rpx;
  background: transparent;
  border: 0;
  border-radius: 50%;
}

.stepper-minus,
.stepper-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 72rpx;
  color: #007c16;
  background: transparent;
  border: 0;
  border-radius: 0;
  font-size: 34rpx;
  font-weight: 800;
}

.stepper-plus-single {
  width: 72rpx;
  height: 72rpx;
  color: #ffffff;
  background: #007c16;
  border-radius: 50%;
}

.stepper-minus[disabled],
.stepper-plus[disabled] {
  color: #cccccc;
  background: transparent;
}

.stepper-value {
  flex-shrink: 0;
  min-width: 72rpx;
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
  white-space: nowrap;
}

.store-cart-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 128rpx;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 2rpx solid #eeeeee;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.cart-summary {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
}

.cart-icon-wrap {
  position: relative;
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
}

.cart-icon {
  width: 96rpx;
  height: 96rpx;
  color: #ffffff;
  background: #007c16;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 96rpx;
  text-align: center;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  color: #ffffff;
  background: #ff6a00;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 32rpx;
  text-align: center;
  white-space: nowrap;
}

.cart-amount-wrap {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.cart-amount {
  overflow: hidden;
  color: #1c1c1e;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-count {
  margin-top: 2rpx;
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checkout-button {
  flex-shrink: 0;
  width: 240rpx;
  height: 96rpx;
  color: #ffffff;
  background: #007c16;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 96rpx;
  text-align: center;
}

.checkout-button[disabled] {
  color: #999999;
  background: #eeeeee;
}

.cart-sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 70;
  background: rgba(0, 0, 0, 0.38);
}

.cart-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
  display: flex;
  width: 100%;
  max-height: 68vh;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
}

.sheet-handle {
  flex-shrink: 0;
  width: 64rpx;
  height: 8rpx;
  margin: 16rpx auto 6rpx;
  background: #d1d5db;
  border-radius: 999rpx;
}

.sheet-header {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 32rpx;
  border-bottom: 2rpx solid #eeeeee;
}

.sheet-store-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #1c1c1e;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 20rpx;
}

.sheet-clear {
  color: #007c16;
  background: transparent;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 40rpx;
  white-space: nowrap;
}

.sheet-close {
  width: 48rpx;
  height: 48rpx;
  color: #1c1c1e;
  background: transparent;
  font-size: 42rpx;
  line-height: 44rpx;
}

.sheet-scroll {
  flex: 1;
  min-height: 0;
  max-height: 48vh;
  padding: 0 32rpx;
}

.sheet-empty {
  padding: 72rpx 0;
  color: #999999;
  font-size: 26rpx;
  text-align: center;
}

.sheet-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #eeeeee;
}

.sheet-item-disabled {
  opacity: 0.72;
}

.sheet-image-wrap {
  flex-shrink: 0;
  width: 144rpx;
  height: 144rpx;
}

.sheet-image {
  display: block;
  width: 144rpx;
  height: 144rpx;
  background: #f1f3f5;
  border-radius: 16rpx;
}

.sheet-main {
  flex: 1;
  min-width: 0;
}

.sheet-title-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  min-width: 0;
}

.sheet-name {
  display: -webkit-box;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  word-break: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.sheet-delete {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  color: #1c1c1e;
  background: transparent;
  font-size: 22rpx;
  line-height: 48rpx;
}

.sheet-stock,
.sheet-invalid {
  margin-top: 8rpx;
  overflow: hidden;
  color: #666666;
  font-size: 22rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-invalid {
  color: #ff6a00;
}

.sheet-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
  margin-top: 14rpx;
}

.sheet-section-title {
  padding-top: 24rpx;
  color: #ff6a00;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 32rpx;
}

.sheet-footer {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #eeeeee;
}

.footer-summary {
  flex: 1;
  min-width: 0;
}

.footer-amount {
  overflow: hidden;
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.footer-amount text {
  color: #ff6a00;
  font-size: 32rpx;
}

.footer-count {
  margin-top: 4rpx;
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.state-card {
  padding: 40rpx 24rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.state-actions {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.list-more {
  padding: 20rpx;
  color: #999999;
  font-size: 24rpx;
  text-align: center;
}
