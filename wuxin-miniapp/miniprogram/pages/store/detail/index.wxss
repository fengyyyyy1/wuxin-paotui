.store-page{min-height:100vh;padding:24rpx 32rpx 0;background:#f6f7f9}.hero-card{position:relative;height:390rpx;overflow:hidden;border-radius:36rpx;box-shadow:0 10rpx 34rpx rgba(0,0,0,.1)}.hero-image,.hero-overlay{position:absolute;width:100%;height:100%}.hero-overlay{background:linear-gradient(180deg,rgba(0,0,0,.04),rgba(0,0,0,.72))}.hero-content{position:absolute;right:0;bottom:0;left:0;padding:34rpx;color:#fff}.hero-top{display:flex;align-items:center;gap:16rpx}.hero-status{padding:7rpx 13rpx;background:rgba(255,255,255,.2);border-radius:10rpx;font-size:20rpx}.hero-status.open{background:#18b566}.hero-hours{font-size:21rpx}.store-name{display:block;margin-top:16rpx;font-size:40rpx;font-weight:800}.store-description{display:block;margin-top:8rpx;overflow:hidden;font-size:23rpx;text-overflow:ellipsis;white-space:nowrap}.store-meta{display:flex;justify-content:space-between;gap:16rpx;margin-top:18rpx;color:rgba(255,255,255,.78);font-size:20rpx}.store-meta text{max-width:55%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.search-card{display:flex;align-items:center;gap:14rpx;margin-top:24rpx;padding:14rpx;background:#fff;border-radius:28rpx}.search-field{display:flex;flex:1;min-width:0;align-items:center;height:72rpx;padding:0 20rpx;background:#f1f3f4;border-radius:22rpx}.search-field image{width:28rpx;height:28rpx;margin-right:12rpx}.search-field input{flex:1;min-width:0;height:72rpx;font-size:25rpx}.search-field button{width:48rpx;color:#999;font-size:30rpx}.search-field button::after,.search-action::after{border:0}.search-action{flex-shrink:0;height:72rpx;padding:0 24rpx;color:#fff;background:#18b566;border-radius:22rpx;font-size:24rpx}
.category-scroll{position:sticky;top:0;z-index:8;width:calc(100% + 64rpx);margin:24rpx -32rpx 0;background:rgba(246,247,249,.96)}.category-row{display:flex;gap:14rpx;padding:18rpx 32rpx}.category{flex-shrink:0;padding:17rpx 28rpx;color:#666;background:#fff;border-radius:26rpx;font-size:24rpx}.category::after{border:0}.category.active{color:#fff;background:#18b566}
.product-list{display:flex;flex-direction:column;gap:20rpx;margin-top:12rpx}.product-card{display:flex;gap:24rpx;padding:24rpx;background:#fff;border-radius:32rpx;box-shadow:0 8rpx 30rpx rgba(0,0,0,.045)}.product-image{flex-shrink:0;width:190rpx;height:190rpx;background:#f0f2f4;border-radius:26rpx}.product-content{flex:1;min-width:0}.product-name{display:block;overflow:hidden;color:#111;font-size:29rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.product-description{display:-webkit-box;margin-top:10rpx;overflow:hidden;color:#999;font-size:22rpx;line-height:31rpx;-webkit-box-orient:vertical;-webkit-line-clamp:2}.product-meta{display:flex;gap:16rpx;margin-top:12rpx;color:#999;font-size:20rpx}.product-bottom{display:flex;align-items:center;justify-content:space-between;gap:12rpx;margin-top:18rpx}.price{color:#ff8a00;font-size:22rpx;font-weight:700}.price-number{font-size:34rpx}.add-button{display:flex;align-items:center;justify-content:center;width:62rpx;height:62rpx;color:#fff;background:#18b566;border-radius:50%;font-size:32rpx}.add-button::after,.stepper button::after{border:0}.add-button[disabled]{background:#d6dad8}.stepper{display:flex;align-items:center;height:62rpx;overflow:hidden;background:#f1f3f4;border-radius:31rpx}.stepper button{display:flex;align-items:center;justify-content:center;width:62rpx;height:62rpx;color:#666;font-size:29rpx}.stepper .plus{color:#fff;background:#18b566}.stepper text{min-width:50rpx;text-align:center;font-size:24rpx}.more-text{padding:28rpx;color:#999;font-size:22rpx;text-align:center}.bottom-spacer{height:150rpx}
.bottom-cart{position:fixed;right:24rpx;bottom:calc(18rpx + env(safe-area-inset-bottom));left:24rpx;z-index:16;display:flex;align-items:center;gap:16rpx;height:112rpx;padding:14rpx 14rpx 14rpx 24rpx;background:rgba(17,17,17,.94);border-radius:34rpx;box-shadow:0 18rpx 48rpx rgba(0,0,0,.2)}.cart-summary{display:flex;flex:1;min-width:0;align-items:center;color:#fff;text-align:left}.cart-summary::after,.checkout::after{border:0}.cart-icon{position:relative;display:flex;align-items:center;justify-content:center;width:70rpx;height:70rpx;background:#fff;border-radius:23rpx}.cart-icon image{width:38rpx;height:38rpx}.badge{position:absolute;top:-10rpx;right:-10rpx;min-width:34rpx;height:34rpx;padding:0 8rpx;color:#fff;background:#ff4d4f;border:3rpx solid #111;border-radius:17rpx;font-size:19rpx;line-height:34rpx;text-align:center}.amount{display:flex;flex-direction:column;margin-left:20rpx}.amount-price{font-size:32rpx;font-weight:800}.amount-caption{margin-top:3rpx;color:rgba(255,255,255,.6);font-size:20rpx}.checkout{display:flex;align-items:center;justify-content:center;min-width:190rpx;height:84rpx;padding:0 32rpx;color:#fff;background:#18b566;border-radius:26rpx;font-size:28rpx;font-weight:700}.checkout[disabled]{color:#aaa;background:#444}
.sheet-layer{position:fixed;z-index:40;inset:0}.sheet-mask{position:absolute;inset:0;background:rgba(0,0,0,.46)}.sheet{position:absolute;right:0;bottom:0;left:0;max-height:76vh;padding-bottom:env(safe-area-inset-bottom);background:#fff;border-radius:40rpx 40rpx 0 0;animation:sheet-up 220ms ease-out}.sheet-header{display:flex;align-items:center;justify-content:space-between;padding:30rpx 32rpx 24rpx;border-bottom:1rpx solid #eee}.sheet-title,.sheet-subtitle{display:block}.sheet-title{font-size:32rpx;font-weight:750}.sheet-subtitle{margin-top:5rpx;color:#999;font-size:21rpx}.sheet-actions{display:flex;align-items:center;gap:20rpx}.sheet-actions button{color:#999;font-size:23rpx}.sheet-actions button::after{border:0}.sheet-actions .close{display:flex;align-items:center;justify-content:center;width:56rpx;height:56rpx;background:#f1f3f4;border-radius:50%;font-size:30rpx}.sheet-list{max-height:720rpx}.sheet-item{display:flex;gap:20rpx;padding:24rpx 32rpx;border-bottom:1rpx solid #eee}.sheet-item image{flex-shrink:0;width:128rpx;height:128rpx;background:#f1f3f4;border-radius:20rpx}.sheet-copy{flex:1;min-width:0}.sheet-name{display:block;overflow:hidden;font-size:27rpx;font-weight:650;text-overflow:ellipsis;white-space:nowrap}.invalid{display:block;margin-top:8rpx;color:#ff4d4f;font-size:21rpx}.sheet-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:25rpx}.sheet-price{color:#ff8a00;font-size:28rpx;font-weight:750}.sheet-footer{display:flex;align-items:center;justify-content:space-between;gap:24rpx;padding:20rpx 32rpx;border-top:1rpx solid #eee}.sheet-total-label{color:#666;font-size:22rpx}.sheet-total{margin-left:10rpx;color:#ff8a00;font-size:34rpx;font-weight:800}@keyframes sheet-up{from{transform:translateY(100%)}to{transform:translateY(0)}}
