.store-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx 0;
  overflow-x: hidden;
  background: #f6f7f9;
}

.hero-card {
  position: relative;
  width: 100%;
  height: 390rpx;
  overflow: hidden;
  border-radius: 36rpx;
  box-shadow: 0 10rpx 34rpx rgba(0, 0, 0, 0.1);
}

.hero-image,
.hero-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.72));
}

.hero-content {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 34rpx;
  color: #ffffff;
}

.hero-top,
.store-meta {
  display: flex;
  align-items: center;
  min-width: 0;
}

.hero-status,
.hero-hours {
  flex-shrink: 0;
  white-space: nowrap;
}

.hero-status {
  padding: 7rpx 13rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 10rpx;
  font-size: 20rpx;
}
.hero-status.open {
  background: #18b566;
}
.hero-hours {
  margin-left: 16rpx;
  font-size: 21rpx;
}

.store-name,
.store-description {
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-name {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 800;
}
.store-description {
  margin-top: 8rpx;
  font-size: 23rpx;
}
.store-meta {
  justify-content: space-between;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 20rpx;
}
.store-meta text {
  min-width: 0;
  max-width: 55%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  margin-top: 24rpx;
  padding: 14rpx;
  overflow: hidden;
  background: #ffffff;
  border-radius: 28rpx;
}

.search-field {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  overflow: hidden;
  background: #f1f3f4;
  border-radius: 22rpx;
}

.search-field image {
  flex-shrink: 0;
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
}
.search-field input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 25rpx;
}
.search-clear {
  display: flex;
  flex: 0 0 48rpx;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 72rpx;
  color: #999999;
  font-size: 30rpx;
}
.search-action {
  display: flex;
  flex: 0 0 136rpx;
  align-items: center;
  justify-content: center;
  width: 136rpx;
  height: 72rpx;
  margin-left: 14rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 22rpx;
  font-size: 24rpx;
  white-space: nowrap;
}
.search-action--pressed {
  opacity: 0.72;
}

.category-scroll {
  position: sticky;
  top: 0;
  z-index: 8;
  width: 100%;
  margin-top: 24rpx;
  overflow: hidden;
  background: rgba(246, 247, 249, 0.96);
}

.category-row {
  display: inline-flex;
  min-width: 100%;
  padding: 18rpx 0;
  white-space: nowrap;
}
.category {
  flex-shrink: 0;
  padding: 17rpx 28rpx;
  color: #666666;
  background: #ffffff;
  border-radius: 26rpx;
  font-size: 24rpx;
  white-space: nowrap;
}
.category + .category {
  margin-left: 14rpx;
}
.category.active {
  color: #ffffff;
  background: #18b566;
}

.product-list {
  width: 100%;
  margin-top: 12rpx;
}
.product-card {
  display: flex;
  width: 100%;
  min-width: 0;
  padding: 24rpx;
  overflow: hidden;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.045);
}
.product-card + .product-card {
  margin-top: 20rpx;
}
.product-image {
  display: block;
  flex: 0 0 180rpx;
  width: 180rpx;
  height: 180rpx;
  margin-right: 22rpx;
  background: #f0f2f4;
  border-radius: 26rpx;
}
.product-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.product-name {
  display: -webkit-box;
  max-height: 76rpx;
  overflow: hidden;
  color: #111111;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 38rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
.product-description {
  display: -webkit-box;
  max-height: 62rpx;
  margin-top: 8rpx;
  overflow: hidden;
  color: #999999;
  font-size: 22rpx;
  line-height: 31rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
.product-meta {
  display: flex;
  min-width: 0;
  margin-top: 10rpx;
  overflow: hidden;
  color: #999999;
  font-size: 20rpx;
  white-space: nowrap;
}
.product-meta text {
  flex-shrink: 0;
}
.product-meta text + text {
  margin-left: 16rpx;
}
.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  margin-top: 14rpx;
}
.price {
  flex-shrink: 0;
  overflow: hidden;
  color: #ff8a00;
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.price-number {
  font-size: 34rpx;
}

.add-button {
  display: flex;
  flex: 0 0 64rpx;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  margin-left: 12rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 50%;
  font-size: 32rpx;
}

.add-button--disabled {
  background: #d6dad8;
}
.stepper {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  height: 62rpx;
  margin-left: 12rpx;
  overflow: hidden;
  background: #f1f3f4;
  border-radius: 31rpx;
  white-space: nowrap;
}
.stepper-button {
  display: flex;
  flex: 0 0 58rpx;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 62rpx;
  color: #666666;
  font-size: 29rpx;
}
.stepper-plus {
  color: #ffffff;
  background: #18b566;
}
.stepper-value {
  flex: 0 0 48rpx;
  min-width: 48rpx;
  text-align: center;
  font-size: 24rpx;
  white-space: nowrap;
}
.more-text {
  padding: 28rpx;
  color: #999999;
  font-size: 22rpx;
  text-align: center;
}
.bottom-spacer {
  height: calc(164rpx + env(safe-area-inset-bottom));
}

.bottom-cart {
  position: fixed;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  z-index: 16;
  display: flex;
  align-items: center;
  min-width: 0;
  height: 112rpx;
  padding: 14rpx 14rpx 14rpx 24rpx;
  background: rgba(17, 17, 17, 0.94);
  border-radius: 34rpx;
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.2);
}

.cart-summary {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  color: #ffffff;
  text-align: left;
}
.cart-summary::after,
.checkout::after {
  border: 0;
}
.cart-icon {
  position: relative;
  display: flex;
  flex: 0 0 70rpx;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  background: #ffffff;
  border-radius: 23rpx;
}
.cart-icon image {
  width: 38rpx;
  height: 38rpx;
}
.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  color: #ffffff;
  background: #ff4d4f;
  border: 3rpx solid #111111;
  border-radius: 17rpx;
  font-size: 19rpx;
  line-height: 34rpx;
  text-align: center;
  white-space: nowrap;
}
.amount {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  margin-left: 20rpx;
  overflow: hidden;
}
.amount-price,
.amount-caption {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.amount-price {
  font-size: 32rpx;
  font-weight: 800;
}
.amount-caption {
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 20rpx;
}
.checkout {
  display: flex;
  flex: 0 0 190rpx;
  align-items: center;
  justify-content: center;
  width: 190rpx;
  min-width: 190rpx;
  height: 84rpx;
  margin-left: 16rpx;
  padding: 0 24rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 26rpx;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}
.checkout[disabled] {
  color: #aaaaaa;
  background: #444444;
}

.sheet-layer {
  position: fixed;
  z-index: 40;
  inset: 0;
}
.sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.46);
}
.sheet {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  max-height: 76vh;
  padding-bottom: env(safe-area-inset-bottom);
  overflow: hidden;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  animation: sheet-up 220ms ease-out;
}
.sheet-header {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 30rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #eeeeee;
}
.sheet-heading {
  flex: 1;
  min-width: 0;
}
.sheet-title,
.sheet-subtitle {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 750;
}
.sheet-subtitle {
  margin-top: 5rpx;
  color: #999999;
  font-size: 21rpx;
}
.sheet-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  margin-left: 20rpx;
}
.sheet-clear {
  padding: 12rpx;
  color: #999999;
  font-size: 23rpx;
  white-space: nowrap;
}
.sheet-close {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin-left: 8rpx;
  background: #f1f3f4;
  border-radius: 50%;
  font-size: 30rpx;
}
.sheet-list {
  max-height: 720rpx;
}
.sheet-item {
  display: flex;
  width: 100%;
  min-width: 0;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eeeeee;
}
.sheet-item image {
  flex: 0 0 128rpx;
  width: 128rpx;
  height: 128rpx;
  margin-right: 20rpx;
  background: #f1f3f4;
  border-radius: 20rpx;
}
.sheet-copy {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.sheet-name {
  display: block;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.invalid {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #ff4d4f;
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sheet-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  margin-top: 25rpx;
}
.sheet-price {
  flex-shrink: 0;
  color: #ff8a00;
  font-size: 28rpx;
  font-weight: 750;
  white-space: nowrap;
}
.sheet-footer {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #eeeeee;
}
.sheet-summary {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
}
.sheet-total-label {
  color: #666666;
  font-size: 22rpx;
}
.sheet-total {
  margin-left: 10rpx;
  color: #ff8a00;
  font-size: 34rpx;
  font-weight: 800;
}

@keyframes sheet-up {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
