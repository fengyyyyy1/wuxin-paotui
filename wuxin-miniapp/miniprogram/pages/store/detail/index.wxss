/* 页面基础 */

.store-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
  padding-bottom: 0;
  box-sizing: border-box;
  background: #f5f6f7;
}

/* 加载、错误、空状态 */

.store-state {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  border-radius: 28rpx;
}

.store-state-action {
  width: 200rpx;
  height: 72rpx;
  margin: 28rpx auto 0;
  padding: 0;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 72rpx;
  border-radius: 22rpx;
}

/* 门店信息卡片 */

.store-hero {
  margin-top: 0;
  padding: 28rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 29, 0.04);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(23, 26, 29, 0.06);
}

.store-hero-top {
  display: flex;
  align-items: flex-start;
  min-width: 0;
}

.store-avatar {
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  margin-right: 22rpx;
  background: #f0f2f3;
  border-radius: 26rpx;
}

.store-info {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.store-name {
  overflow: hidden;
  color: #16191c;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-status-row {
  display: flex;
  align-items: center;
  min-width: 0;
  margin-top: 10rpx;
}

.store-status-badge {
  flex-shrink: 0;
  height: 38rpx;
  margin-right: 12rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 38rpx;
  white-space: nowrap;
}

.status-open {
  color: #128b58;
  background: #e8f7ef;
}

.status-rest {
  color: #7c8288;
  background: #eef0f2;
}

.store-meta {
  min-width: 0;
  margin-top: 8rpx;
  overflow: hidden;
  color: #858b91;
  font-size: 23rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-status-row .store-meta {
  flex: 1;
  margin-top: 0;
}

.store-notice {
  display: -webkit-box;
  margin-top: 24rpx;
  padding-top: 22rpx;
  overflow: hidden;
  color: #555b61;
  font-size: 25rpx;
  line-height: 38rpx;
  border-top: 1rpx solid #f0f1f2;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.store-contact {
  margin-top: 12rpx;
  color: #8a9096;
  font-size: 23rpx;
  line-height: 32rpx;
}

.store-closed-message {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  color: #d96a1c;
  font-size: 23rpx;
  line-height: 34rpx;
  background: #fff4eb;
  border-radius: 18rpx;
}

/* 搜索和分类 */

.store-toolbar {
  margin-top: 28rpx;
}

.store-search {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 14rpx 0 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 29, 0.04);
  border-radius: 26rpx;
  box-shadow: 0 8rpx 28rpx rgba(23, 26, 29, 0.045);
}

.wuxin-search-icon {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  margin-right: 16rpx;
  opacity: 0.58;
}

.wuxin-search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0;
  color: #171a1d;
  font-size: 27rpx;
  line-height: 88rpx;
}

.wuxin-search-placeholder {
  color: #a3a8ad;
}

.store-search-clear {
  flex-shrink: 0;
  min-width: 84rpx;
  height: 60rpx;
  margin-left: 10rpx;
  padding: 0 14rpx;
  color: #16a76a;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 60rpx;
  text-align: center;
  background: transparent;
  border-radius: 18rpx;
}

.store-search-clear[disabled] {
  color: #c4c8cc;
  background: transparent;
}

.store-categories {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.store-category-track {
  display: inline-flex;
  align-items: center;
  min-width: 100%;
  padding-right: 24rpx;
  box-sizing: border-box;
}

.category-chip {
  flex-shrink: 0;
  max-width: 260rpx;
  height: 66rpx;
  margin-right: 14rpx;
  padding: 0 28rpx;
  overflow: hidden;
  color: #666c72;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 66rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 29, 0.04);
  border-radius: 999rpx;
}

.category-chip.wuxin-tag-active {
  color: #ffffff;
  font-weight: 600;
  background: #16a76a;
  border-color: #16a76a;
  box-shadow: 0 8rpx 20rpx rgba(22, 167, 106, 0.2);
}

/* 商品列表 */

.store-products {
  margin-top: 28rpx;
}

.product-card {
  display: flex;
  align-items: stretch;
  min-width: 0;
  margin-bottom: 20rpx;
  padding: 22rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 29, 0.035);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 34rpx rgba(23, 26, 29, 0.05);
}

.product-card:active {
  background: #fafbfb;
  transform: scale(0.995);
}

.product-image-wrap {
  flex-shrink: 0;
  width: 156rpx;
  height: 156rpx;
  margin-right: 22rpx;
  overflow: hidden;
  background: #f0f2f3;
  border-radius: 24rpx;
}

.wuxin-product-image {
  display: block;
  width: 100%;
  height: 100%;
  background: #f0f2f3;
  border-radius: 24rpx;
}

.product-main {
  display: flex;
  flex: 1;
  min-width: 0;
  min-height: 156rpx;
  flex-direction: column;
}

.product-name {
  display: -webkit-box;
  overflow: hidden;
  color: #171a1d;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 40rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.product-description {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  color: #7c8288;
  font-size: 23rpx;
  line-height: 32rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.product-stock {
  margin-top: 4rpx;
  overflow: hidden;
  color: #a0a5aa;
  font-size: 21rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  min-width: 0;
  margin-top: auto;
  padding-top: 10rpx;
}

.product-price {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #ff7417;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-cart-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.wuxin-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  padding: 0;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 400;
  line-height: 54rpx;
  background: #16a76a;
  border-radius: 50%;
  box-shadow: 0 7rpx 18rpx rgba(22, 167, 106, 0.22);
}

.wuxin-stepper {
  display: flex;
  align-items: center;
  height: 58rpx;
  overflow: hidden;
  background: #f2f4f4;
  border-radius: 18rpx;
}

.wuxin-stepper-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  padding: 0;
  color: #16a76a;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 58rpx;
  background: transparent;
}

.wuxin-stepper-value {
  min-width: 48rpx;
  color: #171a1d;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 58rpx;
  text-align: center;
}

.wuxin-add-button[disabled],
.wuxin-stepper-button[disabled] {
  color: #bdc2c6;
  background: #eceeef;
  box-shadow: none;
}

.store-list-note {
  padding: 22rpx 0 14rpx;
  color: #9a9fa4;
  font-size: 23rpx;
  text-align: center;
}

/* 底部购物车占位 */

.store-bottom-placeholder {
  height: calc(164rpx + env(safe-area-inset-bottom));
}

/* 底部购物车 */

.store-cart-bar {
  position: fixed;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 108rpx;
  padding: 0 14rpx 0 18rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(23, 26, 29, 0.05);
  border-radius: 34rpx;
  box-shadow: 0 18rpx 50rpx rgba(23, 26, 29, 0.14);
  backdrop-filter: blur(20rpx);
}

.cart-bar-main {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
}

.cart-icon-area {
  position: relative;
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
}

.cart-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #16a76a;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(22, 167, 106, 0.22);
}

.cart-icon-image {
  width: 36rpx;
  height: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -10rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 7rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
  white-space: nowrap;
  background: #ff7417;
  border: 3rpx solid #ffffff;
  border-radius: 999rpx;
}

.cart-summary {
  flex: 1;
  min-width: 0;
}

.cart-total {
  overflow: hidden;
  color: #171a1d;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-count {
  margin-top: 3rpx;
  overflow: hidden;
  color: #989da2;
  font-size: 21rpx;
  line-height: 29rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-checkout {
  flex-shrink: 0;
  width: 190rpx;
  height: 78rpx;
  margin-left: 14rpx;
  padding: 0;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 78rpx;
  text-align: center;
  background: #16a76a;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(22, 167, 106, 0.2);
}

.cart-checkout-disabled {
  color: #999ea3;
  background: #eceeef;
  box-shadow: none;
}

/* 购物车弹层遮罩 */

.cart-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(15, 18, 20, 0.42);
  backdrop-filter: blur(6rpx);
}

/* 购物车弹层 */

.cart-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 201;
  display: flex;
  max-height: 74vh;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -18rpx 60rpx rgba(23, 26, 29, 0.16);
}

.sheet-handle {
  flex-shrink: 0;
  width: 68rpx;
  height: 8rpx;
  margin: 16rpx auto 4rpx;
  background: #d8dbde;
  border-radius: 999rpx;
}

.sheet-header {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 12rpx 30rpx 18rpx;
  box-sizing: border-box;
}

.sheet-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #171a1d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  margin-left: 20rpx;
}

.sheet-action-button {
  height: 56rpx;
  padding: 0 16rpx;
  color: #16a76a;
  font-size: 24rpx;
  line-height: 56rpx;
  background: transparent;
}

.sheet-action-button[disabled] {
  color: #c5c9cc;
}

.sheet-dismiss-control {
  width: 56rpx;
  height: 56rpx;
  margin-left: 8rpx;
  padding: 0;
  color: #656b70;
  font-size: 38rpx;
  font-weight: 300;
  line-height: 52rpx;
  text-align: center;
  background: #f2f3f4;
  border-radius: 50%;
}

.sheet-list {
  flex: 1;
  min-height: 0;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.sheet-empty {
  padding: 90rpx 0;
  color: #92979c;
  font-size: 26rpx;
  text-align: center;
}

.sheet-item {
  display: flex;
  min-width: 0;
  padding: 22rpx 0;
  border-top: 1rpx solid #eff0f1;
}

.sheet-item-disabled {
  opacity: 0.62;
}

.sheet-product-image {
  flex-shrink: 0;
  width: 104rpx;
  height: 104rpx;
  margin-right: 18rpx;
  background: #f0f2f3;
  border-radius: 20rpx;
}

.sheet-item-main {
  flex: 1;
  min-width: 0;
}

.sheet-item-top {
  display: flex;
  align-items: flex-start;
  min-width: 0;
}

.sheet-product-name {
  display: -webkit-box;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #171a1d;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 36rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.sheet-remove-control {
  flex-shrink: 0;
  height: 42rpx;
  margin-left: 14rpx;
  padding: 0 4rpx;
  color: #a0a5aa;
  font-size: 21rpx;
  line-height: 42rpx;
  background: transparent;
}

.sheet-product-stock,
.sheet-product-invalid {
  margin-top: 5rpx;
  overflow: hidden;
  color: #9da2a7;
  font-size: 21rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-product-invalid {
  color: #e34c52;
}

.sheet-item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  margin-top: 12rpx;
}

.sheet-product-price {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #ff7417;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-section-label {
  padding: 24rpx 0 8rpx;
  color: #999ea3;
  font-size: 22rpx;
  line-height: 32rpx;
}

.sheet-footer {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  padding: 22rpx 30rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eff0f1;
  box-shadow: 0 -8rpx 30rpx rgba(23, 26, 29, 0.04);
}

.sheet-total {
  flex: 1;
  min-width: 0;
}

.sheet-total-label {
  color: #969ba1;
  font-size: 21rpx;
  line-height: 28rpx;
}

.sheet-total-price {
  margin-top: 2rpx;
  overflow: hidden;
  color: #ff7417;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 46rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-checkout {
  flex-shrink: 0;
  width: 200rpx;
  height: 80rpx;
  margin-left: 18rpx;
  padding: 0;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
  text-align: center;
  background: #16a76a;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(22, 167, 106, 0.2);
}

.sheet-checkout-disabled {
  color: #999ea3;
  background: #eceeef;
  box-shadow: none;
}