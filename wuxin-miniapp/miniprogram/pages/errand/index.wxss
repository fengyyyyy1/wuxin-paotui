.errand-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: #f6f7f9;
}

.errand-hero {
  width: 100%;
  padding: 40rpx 36rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 32rpx rgba(24, 181, 102, 0.2);
}

.errand-eyebrow,
.errand-title,
.errand-subtitle {
  display: block;
  width: 100%;
}

.errand-eyebrow {
  color: rgba(255, 255, 255, 0.76);
  font-size: 22rpx;
  font-weight: 600;
}

.errand-title {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
}

.errand-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  line-height: 1.6;
}

.service-panel {
  width: 100%;
  margin-top: 24rpx;
  padding: 30rpx 24rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.04);
}

.service-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
  margin-bottom: 22rpx;
}

.service-heading text:first-child {
  color: #111111;
  font-size: 30rpx;
  font-weight: 750;
}

.service-heading text:last-child {
  flex-shrink: 0;
  margin-left: 20rpx;
  color: #999999;
  font-size: 21rpx;
  white-space: nowrap;
}

.service-row {
  display: flex;
  align-items: stretch;
  width: 100%;
}

.service-row + .service-row {
  margin-top: 16rpx;
}

.service-card {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  min-height: 190rpx;
  padding: 22rpx 10rpx;
  overflow: hidden;
  background: #f8faf9;
  border: 1rpx solid #eef2f0;
  border-radius: 26rpx;
}

.service-card + .service-card {
  margin-left: 16rpx;
}

.service-card--pressed {
  opacity: 0.7;
}

.service-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 21rpx;
  font-size: 23rpx;
  font-weight: 750;
}

.service-title,
.service-description {
  display: block;
  width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-title {
  margin-top: 14rpx;
  color: #111111;
  font-size: 24rpx;
  font-weight: 700;
}

.service-description {
  margin-top: 6rpx;
  color: #999999;
  font-size: 19rpx;
}

.service-notice {
  display: flex;
  align-items: flex-start;
  width: 100%;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  color: #777777;
  background: #ffffff;
  border-radius: 24rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.notice-mark {
  display: flex;
  flex: 0 0 32rpx;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  margin-top: 2rpx;
  margin-right: 14rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 50%;
  font-size: 19rpx;
  font-weight: 700;
}
