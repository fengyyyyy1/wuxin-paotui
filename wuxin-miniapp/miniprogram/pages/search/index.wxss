.search-page{min-height:100vh;padding:24rpx 32rpx 48rpx;background:#f6f7f9}.search-bar{display:flex;align-items:center;gap:14rpx;height:88rpx;padding-left:24rpx;background:#ffffff;border-radius:28rpx;box-shadow:0 8rpx 28rpx rgba(0,0,0,.04)}.search-bar image{flex-shrink:0;width:30rpx;height:30rpx}.search-bar input{flex:1;min-width:0;height:88rpx;color:#111111;font-size:27rpx}.clear{flex-shrink:0;width:56rpx;color:#999999;background:transparent;font-size:32rpx}.submit{flex-shrink:0;height:64rpx;margin-right:12rpx;padding:0 24rpx;color:#ffffff;background:#18b566;border-radius:22rpx;font-size:25rpx}.clear::after,.submit::after{border:0}.suggestions{margin-top:12rpx;padding:8rpx 24rpx;background:#ffffff;border-radius:24rpx;box-shadow:0 8rpx 28rpx rgba(0,0,0,.05)}.suggestions button{display:flex;align-items:center;justify-content:space-between;width:100%;padding:22rpx 0;color:#666666;background:transparent;border-bottom:1rpx solid #eeeeee;font-size:25rpx;text-align:left}.suggestions button:last-child{border-bottom:0}.suggestions button::after{border:0}.search-section,.result-section{margin-top:42rpx}.section-title-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20rpx;color:#111111;font-size:31rpx;font-weight:700}.section-title-row button{padding:8rpx;color:#999999;background:transparent;font-size:22rpx}.section-title-row button::after{border:0}.keyword-list{display:flex;flex-wrap:wrap;gap:16rpx}.keyword-list button{padding:16rpx 24rpx;color:#666666;background:#ffffff;border-radius:24rpx;font-size:23rpx}.keyword-list button::after{border:0}.store-list{display:flex;flex-direction:column;gap:20rpx}.result-title{display:block;margin-bottom:20rpx;color:#111111;font-size:31rpx;font-weight:700}
