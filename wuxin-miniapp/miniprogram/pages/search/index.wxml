<view class="search-page">
  <view class="search-bar"><image src="/assets/images/icons/search-line.svg" /><input value="{{keyword}}" placeholder="搜索门店名称" confirm-type="search" focus bindinput="onInput" bindconfirm="submitSearch" /><view wx:if="{{keyword}}" class="clear" bindtap="clearInput">×</view><view class="submit" bindtap="submitSearch">搜索</view></view>
  <view wx:if="{{suggestions.length}}" class="suggestions"><button wx:for="{{suggestions}}" wx:key="*this" data-value="{{item}}" bindtap="useKeyword"><text>{{item}}</text><text>›</text></button></view>

  <block wx:if="{{!searched}}">
    <view wx:if="{{history.length}}" class="search-section"><view class="section-title-row"><text>搜索历史</text><button bindtap="clearHistory">清空</button></view><view class="keyword-list"><button wx:for="{{history}}" wx:key="*this" data-value="{{item}}" bindtap="useKeyword">{{item}}</button></view></view>
    <view wx:if="{{discoveryStores.length}}" class="search-section"><view class="section-title-row"><text>热门搜索</text></view><view class="keyword-list"><button wx:for="{{discoveryStores}}" wx:key="storeId" wx:if="{{index < 8}}" data-value="{{item.storeName}}" bindtap="useKeyword">{{item.storeName}}</button></view></view>
    <view wx:if="{{recentStores.length}}" class="search-section"><view class="section-title-row"><text>最近浏览</text></view><view class="store-list"><store-card wx:for="{{recentStores}}" wx:key="storeId" store="{{item}}" bind:select="openStore" bind:imageerror="handleImageError" /></view></view>
  </block>

  <view wx:else class="result-section">
    <text class="result-title">搜索结果</text>
    <view class="store-list"><store-card wx:for="{{stores}}" wx:key="storeId" store="{{item}}" bind:select="openStore" bind:imageerror="handleImageError" /></view>
    <page-state loading="{{loading}}" error="{{errorMessage}}" empty="{{!loading && !errorMessage && stores.length === 0}}" empty-title="没有找到相关门店" empty-description="换一个关键词试试" bind:retry="retry" />
  </view>
</view>
