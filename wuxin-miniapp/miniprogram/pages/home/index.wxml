<view class="home-page">
  <view class="topbar">
    <button class="location" bindtap="goToAddress"><text class="location-pin">●</text><text class="location-text">{{addressText}}</text><text>›</text></button>
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" binderror="handleAvatarError" />
  </view>
  <view class="hello"><text class="hello-caption">你好，{{displayName}}</text><text class="hello-title">今天想要点什么？</text></view>
  <button class="search-entry" bindtap="goToSearch"><image src="/assets/images/icons/search-line.svg" /><text>搜索门店或商品</text></button>

  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skeleton banner-skeleton"></view><view class="skeleton service-skeleton"></view><view class="skeleton card-skeleton"></view>
  </view>
  <block wx:else>
    <swiper class="banner" autoplay circular interval="4200" indicator-dots indicator-color="rgba(255,255,255,.45)" indicator-active-color="#ffffff">
      <swiper-item wx:for="{{banners}}" wx:key="id"><view class="banner-item" data-id="{{item.id}}" bindtap="handleBannerTap"><image src="{{item.imageUrl}}" mode="aspectFill" /><view class="banner-copy"><text class="banner-title">{{item.title}}</text><text class="banner-subtitle">{{item.subtitle}}</text></view></view></swiper-item>
    </swiper>

    <view class="service-grid">
      <button class="service-item" wx:for="{{serviceEntries}}" wx:key="id" data-id="{{item.id}}" bindtap="handleServiceTap"><text class="service-icon">{{item.iconText}}</text><text class="service-title">{{item.title}}</text><text class="service-description">{{item.description}}</text></button>
    </view>

    <view class="home-section">
      <section-header title="公益专区" subtitle="免费公益信息与安全指引" />
      <scroll-view class="public-scroll" scroll-x enhanced show-scrollbar="{{false}}"><view class="public-row"><view class="public-card public-{{item.accent}}" wx:for="{{publicEntries}}" wx:key="id" data-id="{{item.id}}" bindtap="goToPublicPage"><text class="public-label">{{item.label}}</text><text class="public-title">{{item.title}}</text><text class="public-description">{{item.description}}</text><text class="public-link">查看详情 ›</text></view></view></scroll-view>
    </view>

    <view id="store-section" class="home-section">
      <section-header title="附近商家" subtitle="真实营业状态，以门店信息为准" action-text="全部门店" bind:action="goToStoreList" />
      <view class="store-list"><store-card wx:for="{{stores}}" wx:key="storeId" store="{{item}}" bind:select="goToStoreDetail" bind:imageerror="handleStoreImageError" /></view>
      <page-state error="{{errorMessage}}" empty="{{!errorMessage && stores.length === 0}}" empty-title="附近暂无门店" empty-description="稍后再来看看" bind:retry="retry" />
    </view>

    <view wx:if="{{hotProducts.length}}" class="home-section"><section-header title="热门商品" subtitle="按真实商品销量排序" /><view class="product-grid"><product-card wx:for="{{hotProducts}}" wx:key="productId" product="{{item}}" bind:select="goToProductDetail" bind:add="addProduct" bind:imageerror="handleProductImageError" /></view></view>
    <view wx:if="{{recommendedProducts.length}}" class="home-section"><section-header title="推荐商品" subtitle="来自附近营业门店" /><view class="product-grid"><product-card wx:for="{{recommendedProducts}}" wx:key="productId" product="{{item}}" bind:select="goToProductDetail" bind:add="addProduct" bind:imageerror="handleProductImageError" /></view></view>
    <view wx:if="{{favoriteProducts.length}}" class="home-section"><section-header title="猜你喜欢" subtitle="继续发现更多本地好物" /><view class="product-grid"><product-card wx:for="{{favoriteProducts}}" wx:key="productId" product="{{item}}" bind:select="goToProductDetail" bind:add="addProduct" bind:imageerror="handleProductImageError" /></view></view>
  </block>
</view>
