<view class="public-page"><view class="public-hero"><text class="hero-label">{{content.label}}</text><text class="hero-title">{{content.title}}</text><text class="hero-intro">{{content.intro}}</text></view><view class="tabs"><button class="{{activeType === 'missing' ? 'active' : ''}}" data-type="missing" bindtap="selectType">走失儿童</button><button class="{{activeType === 'rescue' ? 'active' : ''}}" data-type="rescue" bindtap="selectType">紧急救援</button><button class="{{activeType === 'bullying' ? 'active' : ''}}" data-type="bullying" bindtap="selectType">反校园欺凌</button></view><view class="guide-card"><text class="guide-title">安全指引</text><view class="guide-item" wx:for="{{content.steps}}" wx:key="*this"><text class="number">{{index + 1}}</text><text>{{item}}</text></view></view><view class="notice"><text class="notice-title">重要说明</text><text>{{content.notice}}</text></view><view class="emergency"><text>紧急电话</text><view><text>110 公安报警</text><text>120 医疗急救</text><text>119 火警救援</text></view></view></view>
