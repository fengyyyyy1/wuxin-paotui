.public-page{min-height:100vh;padding:24rpx 32rpx 48rpx;background:#f6f7f9}.public-hero{padding:40rpx 34rpx;color:#fff;background:#18b566;border-radius:36rpx}.hero-label,.hero-title,.hero-intro{display:block}.hero-label{font-size:22rpx}.hero-title{margin-top:18rpx;font-size:42rpx;font-weight:800}.hero-intro{margin-top:14rpx;color:rgba(255,255,255,.82);font-size:24rpx;line-height:1.6}.tabs{display:flex;gap:12rpx;margin-top:22rpx}.tabs button{flex:1;height:72rpx;color:#666;background:#fff;border-radius:22rpx;font-size:21rpx}.tabs button::after{border:0}.tabs .active{color:#fff;background:#111}.guide-card,.notice,.emergency{margin-top:22rpx;padding:30rpx;background:#fff;border-radius:32rpx}.guide-title{display:block;margin-bottom:26rpx;font-size:29rpx;font-weight:750}.guide-item{display:flex;align-items:flex-start;gap:18rpx;margin-bottom:24rpx;color:#555;font-size:23rpx;line-height:1.6}.guide-item:last-child{margin-bottom:0}.number{display:flex;flex-shrink:0;align-items:center;justify-content:center;width:48rpx;height:48rpx;color:#18b566;background:#eaf8f0;border-radius:15rpx;font-weight:700}.notice{color:#8a6338;background:#fff4e6;font-size:22rpx;line-height:1.65}.notice-title{display:block;margin-bottom:10rpx;color:#d97000;font-size:25rpx;font-weight:700}.emergency>text{font-size:27rpx;font-weight:700}.emergency view{display:flex;flex-direction:column;gap:16rpx;margin-top:20rpx;color:#666;font-size:23rpx}
