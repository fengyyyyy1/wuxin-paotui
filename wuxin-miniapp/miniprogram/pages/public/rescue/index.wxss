.public-page {
  padding-bottom: 64rpx;
}

.public-card {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
}

.tag {
  display: inline-flex;
  padding: 6rpx 16rpx;
  color: #b45309;
  background: #fef3c7;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.title {
  margin-top: 20rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.text {
  margin-top: 16rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.75;
}
