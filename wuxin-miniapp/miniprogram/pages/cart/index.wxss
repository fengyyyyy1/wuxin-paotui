.cart-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx calc(176rpx + env(safe-area-inset-bottom));
  background: #f6f7f9;
}

.cart-page view,
.cart-page image,
.cart-page button {
  box-sizing: border-box;
}

.cart-header,
.cart-store-card,
.cart-list,
.cart-state {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 32rpx;
}

.cart-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #1c1c1e;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-refresh,
.state-action,
.store-clear,
.invalid-clear,
.select-box,
.item-delete,
.stepper-minus,
.stepper-plus,
.select-all,
.checkout-button {
  flex-shrink: 0;
  margin: 0;
  padding: 0;
  border: 0;
  line-height: normal;
}

.cart-refresh::after,
.state-action::after,
.store-clear::after,
.invalid-clear::after,
.select-box::after,
.item-delete::after,
.stepper-minus::after,
.stepper-plus::after,
.select-all::after,
.checkout-button::after {
  border: 0;
}

.cart-refresh {
  width: 120rpx;
  height: 64rpx;
  color: #007c16;
  background: #edf7ef;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.cart-store-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 16rpx;
  margin-top: 24rpx;
  padding: 32rpx;
}

.store-label {
  grid-column: 1;
  color: #666666;
  font-size: 22rpx;
  line-height: 30rpx;
}

.store-name {
  grid-column: 1;
  max-width: 100%;
  margin-top: 6rpx;
  overflow: hidden;
  color: #1c1c1e;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-clear {
  grid-row: 1 / span 2;
  grid-column: 2;
  color: #007c16;
  background: transparent;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.cart-list {
  margin-top: 24rpx;
  padding: 32rpx;
}

.cart-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-section-title {
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.cart-section-empty {
  padding: 40rpx 0 12rpx;
  color: #999999;
  font-size: 26rpx;
  text-align: center;
}

.invalid-clear {
  color: #007c16;
  background: transparent;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.invalid-list {
  background: #fffaf6;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #eeeeee;
}

.cart-item:last-child {
  border-bottom: 0;
}

.invalid-item {
  opacity: 0.76;
}

.select-wrap {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 144rpx;
}

.select-box {
  width: 40rpx;
  height: 40rpx;
  color: #ffffff;
  background: #ffffff;
  border: 2rpx solid #cbd5e1;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: center;
}

.select-box-active {
  background: #007c16;
  border-color: #007c16;
}

.invalid-tag {
  width: 56rpx;
  height: 34rpx;
  color: #ffffff;
  background: #999999;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
  white-space: nowrap;
}

.item-image-wrap {
  flex-shrink: 0;
  width: 144rpx;
  height: 144rpx;
}

.item-image {
  display: block;
  width: 144rpx;
  height: 144rpx;
  background: #f1f3f5;
  border-radius: 16rpx;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  min-width: 0;
}

.item-name {
  display: -webkit-box;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  word-break: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  color: #1c1c1e;
  background: transparent;
  font-size: 22rpx;
  line-height: 48rpx;
}

.item-stock,
.item-invalid {
  margin-top: 8rpx;
  overflow: hidden;
  color: #666666;
  font-size: 22rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-invalid {
  color: #ff6a00;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
  margin-top: 14rpx;
}

.item-price {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #ff6a00;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price text {
  font-size: 24rpx;
  font-weight: 800;
}

.item-stepper {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  min-width: 184rpx;
  height: 72rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #edf2f7;
  border-radius: 36rpx;
  white-space: nowrap;
}

.stepper-minus,
.stepper-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 72rpx;
  color: #007c16;
  background: transparent;
  border: 0;
  border-radius: 0;
  font-size: 34rpx;
  font-weight: 800;
}

.stepper-minus[disabled],
.stepper-plus[disabled] {
  color: #cccccc;
  background: transparent;
}

.stepper-value {
  flex-shrink: 0;
  min-width: 72rpx;
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
  white-space: nowrap;
}

.cart-footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 128rpx;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 2rpx solid #eeeeee;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.select-all {
  width: 128rpx;
  height: 96rpx;
  color: #007c16;
  background: #edf7ef;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 96rpx;
  white-space: nowrap;
}

.select-all-active {
  color: #ffffff;
  background: #007c16;
}

.cart-total {
  flex: 1;
  min-width: 0;
}

.total-amount {
  overflow: hidden;
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.total-amount text {
  color: #ff6a00;
  font-size: 32rpx;
}

.total-count {
  margin-top: 4rpx;
  overflow: hidden;
  color: #666666;
  font-size: 24rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checkout-button {
  width: 240rpx;
  height: 96rpx;
  color: #ffffff;
  background: #007c16;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 96rpx;
  text-align: center;
}

.checkout-button[disabled],
.select-all[disabled] {
  color: #999999;
  background: #eeeeee;
}

.cart-state {
  margin-top: 24rpx;
  padding: 48rpx 24rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.state-action {
  width: 180rpx;
  height: 72rpx;
  margin: 24rpx auto 0;
  color: #ffffff;
  background: #007c16;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}
