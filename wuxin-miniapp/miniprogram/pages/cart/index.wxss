.cart-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx calc(176rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: #f6f7f9;
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
  margin: 12rpx 0 28rpx;
}
.cart-header__copy {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}
.cart-title,
.cart-subtitle {
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-title {
  color: #111111;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}
.cart-subtitle {
  margin-top: 6rpx;
  color: #999999;
  font-size: 23rpx;
  line-height: 1.4;
}
.cart-header__actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
}
.cart-header__action {
  flex-shrink: 0;
  min-width: 72rpx;
  padding: 12rpx 8rpx;
  color: #666666;
  font-size: 22rpx;
  white-space: nowrap;
}
.cart-header__action + .cart-header__action {
  margin-left: 8rpx;
}
.cart-header__action--danger {
  color: #ff4d4f;
}
.cart-header__action::after,
.cart-item__select::after,
.cart-item__delete::after,
.cart-stepper__button::after,
.cart-settlement__select::after,
.cart-settlement__button::after {
  border: 0;
}

.cart-store {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 24rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
}
.cart-store__dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-right: 14rpx;
  background: #18b566;
  border-radius: 50%;
}
.cart-store__name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #111111;
  font-size: 27rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-store__arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #aaaaaa;
  font-size: 30rpx;
  white-space: nowrap;
}
.cart-list {
  width: 100%;
  margin-top: 20rpx;
}

.cart-item {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 24rpx;
  overflow: hidden;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
  animation: cart-item-in 220ms ease-out;
}

.cart-item + .cart-item {
  margin-top: 20rpx;
}
.cart-item--invalid {
  opacity: 0.65;
}
.cart-item__select {
  display: flex;
  flex: 0 0 42rpx;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0;
  color: #ffffff;
  background: #ffffff;
  border: 2rpx solid #d7dadd;
  border-radius: 50%;
  font-size: 22rpx;
  line-height: 42rpx;
}
.cart-item__select--checked {
  background: #18b566;
  border-color: #18b566;
}
.cart-item__image {
  display: block;
  flex: 0 0 160rpx;
  width: 160rpx;
  min-width: 160rpx;
  height: 160rpx;
  margin-left: 16rpx;
  background: #f0f2f4;
  border-radius: 24rpx;
}

.cart-item__info {
  position: relative;
  flex: 1;
  min-width: 0;
  min-height: 160rpx;
  margin-left: 20rpx;
  padding-right: 4rpx;
  overflow: hidden;
}

.cart-item__delete {
  position: absolute;
  top: -8rpx;
  right: -2rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  padding: 0;
  color: #999999;
  font-size: 28rpx;
  line-height: 56rpx;
}
.cart-item__name {
  display: -webkit-box;
  max-height: 76rpx;
  padding-right: 60rpx;
  overflow: hidden;
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
  overflow-wrap: break-word;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
.cart-item__meta {
  display: block;
  width: 100%;
  margin-top: 10rpx;
  padding-right: 60rpx;
  overflow: hidden;
  color: #999999;
  font-size: 21rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-item__meta--invalid {
  color: #ff4d4f;
}
.cart-item__bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
  margin-top: 14rpx;
}
.cart-item__price {
  flex-shrink: 0;
  max-width: 150rpx;
  overflow: hidden;
  color: #ff8a00;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 56rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-item__currency {
  margin-right: 2rpx;
  font-size: 20rpx;
}

.cart-stepper {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  width: 166rpx;
  min-width: 166rpx;
  height: 56rpx;
  margin-left: 12rpx;
  overflow: hidden;
  background: #f1f3f4;
  border-radius: 28rpx;
  white-space: nowrap;
}
.cart-stepper__button {
  display: flex;
  flex: 0 0 56rpx;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  padding: 0;
  color: #666666;
  font-size: 27rpx;
  line-height: 56rpx;
}
.cart-stepper__button--plus {
  color: #ffffff;
  background: #18b566;
}
.cart-stepper__button[disabled] {
  opacity: 0.45;
}
.cart-stepper__value {
  flex: 0 0 54rpx;
  width: 54rpx;
  min-width: 54rpx;
  overflow: hidden;
  color: #111111;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-settlement {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -8rpx 28rpx rgba(0, 0, 0, 0.05);
}
.cart-settlement__select {
  display: flex;
  flex: 0 0 104rpx;
  align-items: center;
  width: 104rpx;
  min-width: 104rpx;
  height: 72rpx;
  padding: 0;
  color: #666666;
  font-size: 23rpx;
  white-space: nowrap;
}
.cart-settlement__check {
  display: flex;
  flex: 0 0 40rpx;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  min-width: 40rpx;
  height: 40rpx;
  color: #ffffff;
  background: #ffffff;
  border: 2rpx solid #d7dadd;
  border-radius: 50%;
  font-size: 21rpx;
  line-height: 40rpx;
}
.cart-settlement__check--checked {
  background: #18b566;
  border-color: #18b566;
}
.cart-settlement__select-text {
  flex-shrink: 0;
  margin-left: 10rpx;
  white-space: nowrap;
}
.cart-settlement__summary {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  justify-content: center;
  margin: 0 20rpx;
  overflow: hidden;
}
.cart-settlement__amount {
  display: flex;
  align-items: baseline;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
}
.cart-settlement__label {
  flex-shrink: 0;
  color: #666666;
  font-size: 21rpx;
  white-space: nowrap;
}
.cart-settlement__price {
  min-width: 0;
  overflow: hidden;
  color: #ff8a00;
  font-size: 32rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-settlement__caption {
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  color: #999999;
  font-size: 19rpx;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-settlement__button {
  display: flex;
  flex: 0 0 220rpx;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  min-width: 220rpx;
  height: 88rpx;
  padding: 0 24rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 28rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 88rpx;
  white-space: nowrap;
}
.cart-settlement__button--disabled {
  color: #ffffff;
  background: #cfd5d2;
}

@keyframes cart-item-in {
  from {
    opacity: 0;
    transform: translateY(14rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
