.cart-page{min-height:100vh;padding:24rpx 32rpx 0;background:#f6f7f9}.cart-header{display:flex;align-items:flex-end;justify-content:space-between;gap:20rpx;margin:12rpx 0 28rpx}.title,.subtitle{display:block}.title{font-size:44rpx;font-weight:800}.subtitle{margin-top:6rpx;color:#999;font-size:23rpx}.header-actions{display:flex;gap:18rpx}.header-actions button{padding:8rpx;color:#666;font-size:22rpx}.header-actions button::after{border:0}.header-actions .danger{color:#ff4d4f}.store-card{display:flex;align-items:center;padding:24rpx 28rpx;background:#fff;border-radius:28rpx;font-size:27rpx;font-weight:650}.store-dot{width:14rpx;height:14rpx;margin-right:14rpx;background:#18b566;border-radius:50%}.store-arrow{margin-left:auto;color:#aaa}.cart-list{display:flex;flex-direction:column;gap:20rpx;margin-top:20rpx}.cart-item{display:flex;align-items:center;gap:20rpx;padding:24rpx;background:#fff;border-radius:32rpx;box-shadow:0 8rpx 30rpx rgba(0,0,0,.04);animation:item-in 220ms ease-out}.invalid-item{opacity:.65}.select-button{display:flex;flex-shrink:0;align-items:center;justify-content:center;width:42rpx;height:42rpx;color:#fff;background:#fff;border:2rpx solid #d7dadd;border-radius:50%;font-size:22rpx}.select-button::after{border:0}.select-button.selected{background:#18b566;border-color:#18b566}.product-image{flex-shrink:0;width:154rpx;height:154rpx;background:#f0f2f4;border-radius:24rpx}.item-content{flex:1;min-width:0}.item-top{display:flex;align-items:flex-start;gap:12rpx}.product-name{flex:1;min-width:0;overflow:hidden;font-size:28rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.delete{flex-shrink:0;width:46rpx;color:#aaa;font-size:28rpx}.delete::after{border:0}.stock,.invalid-reason{display:block;margin-top:12rpx;color:#999;font-size:21rpx}.invalid-reason{color:#ff4d4f}.item-bottom{display:flex;align-items:center;justify-content:space-between;gap:12rpx;margin-top:24rpx}.price{color:#ff8a00;font-size:29rpx;font-weight:800}.price text:first-child{font-size:20rpx}.stepper{display:flex;align-items:center;height:58rpx;overflow:hidden;background:#f1f3f4;border-radius:29rpx}.stepper button{display:flex;align-items:center;justify-content:center;width:58rpx;height:58rpx;color:#666;font-size:28rpx}.stepper button::after{border:0}.stepper .plus{color:#fff;background:#18b566}.stepper button[disabled]{opacity:.45}.stepper text{min-width:48rpx;text-align:center;font-size:23rpx}.bottom-space{height:152rpx}.settlement-bar{position:fixed;right:0;bottom:0;left:0;z-index:20;display:flex;align-items:center;gap:18rpx;padding:16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.97);border-top:1rpx solid #eee}.select-all{display:flex;align-items:center;gap:10rpx;color:#666;font-size:23rpx}.select-all::after,.checkout::after{border:0}.total{display:flex;flex:1;min-width:0;flex-wrap:wrap;align-items:baseline}.total-label{color:#666;font-size:21rpx}.total-price{margin-left:8rpx;color:#ff8a00;font-size:34rpx;font-weight:800}.total-caption{width:100%;margin-top:3rpx;color:#999;font-size:19rpx}.checkout{display:flex;align-items:center;justify-content:center;min-width:184rpx;height:88rpx;padding:0 28rpx;color:#fff;background:#18b566;border-radius:28rpx;font-size:27rpx;font-weight:700}.checkout[disabled]{background:#cfd5d2}@keyframes item-in{from{opacity:0;transform:translateY(14rpx)}to{opacity:1;transform:translateY(0)}}
