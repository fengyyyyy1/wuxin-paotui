.checkout-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx 0;
  overflow-x: hidden;
  background: #f6f7f9;
}
.page-title,
.page-subtitle {
  display: block;
}
.page-title {
  font-size: 44rpx;
  font-weight: 800;
}
.page-subtitle {
  margin-top: 8rpx;
  color: #999;
  font-size: 23rpx;
}
.address-card {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 28rpx;
  padding: 28rpx;
  color: #111;
  background: #fff;
  border-radius: 32rpx;
  text-align: left;
}
.address-card::after {
  border: 0;
}
.address-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 23rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.address-copy {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}
.receiver-line {
  display: flex;
  align-items: center;
  min-width: 0;
  overflow: hidden;
}
.receiver {
  min-width: 0;
  max-width: 230rpx;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.phone {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #666;
  font-size: 23rpx;
}
.default-tag {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 5rpx 10rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 9rpx;
  font-size: 18rpx;
}
.address-text {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  color: #666;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.arrow {
  flex-shrink: 0;
  margin-left: 14rpx;
  color: #aaa;
  font-size: 34rpx;
}
.order-card,
.amount-card {
  margin-top: 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 32rpx;
}
.store-title {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
  font-weight: 700;
}
.store-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  background: #18b566;
  border-radius: 50%;
}
.store-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.order-item {
  display: flex;
  min-width: 0;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eee;
}
.order-item image {
  flex-shrink: 0;
  width: 128rpx;
  height: 128rpx;
  margin-right: 20rpx;
  background: #f0f2f4;
  border-radius: 20rpx;
}
.item-copy {
  flex: 1;
  min-width: 0;
}
.item-name {
  display: block;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-stock {
  display: block;
  margin-top: 8rpx;
  color: #999;
  font-size: 20rpx;
}
.item-copy view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
}
.item-price {
  flex-shrink: 0;
  color: #ff8a00;
  font-size: 26rpx;
  font-weight: 750;
}
.quantity {
  flex-shrink: 0;
  color: #666;
  font-size: 22rpx;
}
.remark-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 24rpx;
  font-size: 25rpx;
}
.remark-row input {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
}
.amount-card view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  color: #666;
  font-size: 24rpx;
}
.amount-card .coupon {
  color: #999;
}
.amount-card .amount-total {
  margin: 0;
  padding-top: 22rpx;
  color: #111;
  border-top: 1rpx solid #eee;
  font-weight: 650;
}
.amount-total text:last-child {
  color: #ff8a00;
  font-size: 34rpx;
  font-weight: 800;
}
.bottom-space {
  height: calc(140rpx + env(safe-area-inset-bottom));
}
.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.97);
  border-top: 1rpx solid #eee;
}
.submit-summary {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
}
.submit-label {
  color: #666;
  font-size: 22rpx;
}
.submit-price {
  margin-left: 8rpx;
  color: #ff8a00;
  font-size: 36rpx;
  font-weight: 800;
  white-space: nowrap;
}
.submit-bar button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 220rpx;
  width: 220rpx;
  min-width: 220rpx;
  height: 92rpx;
  padding: 0 34rpx;
  color: #fff;
  background: #18b566;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}
.submit-bar button::after {
  border: 0;
}
.submit-bar button[disabled] {
  background: #cfd5d2;
}
