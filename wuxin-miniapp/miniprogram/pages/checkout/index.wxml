<view class="checkout-page">
  <text class="page-title">确认订单</text>
  <text class="page-subtitle">确认配送信息与商品明细</text>
  <page-state loading="{{loading}}" error="{{errorMessage}}" bind:retry="retry" />
  <block wx:if="{{!loading}}">
    <button class="address-card" bindtap="chooseAddress">
      <view class="address-icon">址</view>
      <view wx:if="{{address}}" class="address-copy"><view class="receiver-line"><text class="receiver">{{address.receiverName}}</text><text class="phone">{{address.maskedPhone}}</text><text wx:if="{{address.isDefault === 1}}" class="default-tag">默认</text></view><text class="address-text">{{address.fullAddress}}</text></view>
      <view wx:else class="address-copy"><text class="receiver">请选择收货地址</text><text class="address-text">订单需要有效的配送地址</text></view><text class="arrow">›</text>
    </button>
    <view wx:if="{{preview}}" class="order-card">
      <view class="store-title"><text class="store-dot"></text><text class="store-name">{{preview.storeName}}</text></view>
      <view class="order-item" wx:for="{{items}}" wx:key="productId"><image src="{{item.imageUrl}}" mode="aspectFill" data-id="{{item.productId}}" binderror="handleImageError" /><view class="item-copy"><text class="item-name">{{item.productName}}</text><text class="item-stock">库存 {{item.stock}}</text><view><text class="item-price">¥{{item.priceText}}</text><text class="quantity">×{{item.quantity}}</text></view></view></view>
      <view class="remark-row"><text>订单备注</text><input value="{{remark}}" maxlength="500" placeholder="口味、配送等要求" bindinput="onRemarkInput" /></view>
    </view>
    <view wx:if="{{preview}}" class="amount-card"><view><text>商品金额</text><text>¥{{productAmountText}}</text></view><view><text>配送费</text><text>¥{{deliveryFeeText}}</text></view><view class="coupon"><text>优惠</text><text>暂无可用优惠</text></view><view class="amount-total"><text>合计</text><text>¥{{totalAmountText}}</text></view></view>
    <view class="bottom-space"></view>
    <view class="submit-bar"><view class="submit-summary"><text class="submit-label">应付</text><text class="submit-price">¥{{totalAmountText}}</text></view><button loading="{{submitting}}" disabled="{{submitting || !preview || !address}}" bindtap="submitOrder">提交订单</button></view>
  </block>
</view>
