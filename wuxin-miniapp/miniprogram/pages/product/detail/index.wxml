<view class="product-page">
  <page-state loading="{{loading}}" error="{{errorMessage}}" empty="{{!loading && !errorMessage && !product}}" empty-title="商品不存在" bind:retry="refresh" />
  <block wx:if="{{product}}">
    <view class="media-card"><image src="{{product.imageUrl}}" mode="aspectFill" binderror="handleImageError" /><text wx:if="{{!product.canAddToCart}}" class="availability">{{product.statusText}}</text></view>
    <view class="detail-card">
      <view class="price-row"><view class="price"><text>¥</text><text class="price-number">{{product.priceText}}</text></view><text class="stock">{{product.stockText}}</text></view>
      <text class="product-name">{{product.productName}}</text>
      <view class="meta-row"><text wx:if="{{product.categoryName}}">{{product.categoryName}}</text><text wx:if="{{product.sales !== null && product.sales !== undefined}}">已售 {{product.sales}}</text><text>{{product.statusText}}</text></view>
      <view class="divider"></view>
      <text class="section-title">商品介绍</text>
      <text class="description">{{product.productDescription || '商家暂未填写商品介绍'}}</text>
    </view>
    <view class="service-card"><view><text class="service-icon">✓</text><text>商品信息来自商家实时维护</text></view><view><text class="service-icon">✓</text><text>库存与价格以下单结算为准</text></view></view>
    <view class="bottom-space"></view>
    <view class="action-bar">
      <button class="cart-entry" bindtap="goToCart"><view class="cart-icon"><image src="/assets/images/icons/cart-line.svg" /><text wx:if="{{cartCount}}">{{cartCount}}</text></view><text>购物车</text></button>
      <button class="add-cart" loading="{{addingCart}}" disabled="{{addingCart || !product.canAddToCart}}" bindtap="handleCartClick">{{product.cartButtonText}}</button>
    </view>
  </block>
</view>
