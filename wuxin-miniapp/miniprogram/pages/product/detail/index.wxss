.product-page{min-height:100vh;padding:24rpx 32rpx 0;background:#f6f7f9}.media-card{position:relative;overflow:hidden;background:#fff;border-radius:36rpx;box-shadow:0 8rpx 32rpx rgba(0,0,0,.05)}.media-card image{display:block;width:100%;aspect-ratio:1/1;background:#f0f2f4}.availability{position:absolute;top:24rpx;left:24rpx;padding:10rpx 18rpx;color:#fff;background:rgba(17,17,17,.7);border-radius:14rpx;font-size:22rpx}.detail-card,.service-card{margin-top:24rpx;padding:30rpx;background:#fff;border-radius:32rpx}.price-row{display:flex;align-items:center;justify-content:space-between}.price{color:#ff8a00;font-size:24rpx;font-weight:700}.price-number{font-size:46rpx;font-weight:800}.stock{color:#999;font-size:22rpx}.product-name{display:block;margin-top:18rpx;color:#111;font-size:36rpx;font-weight:800;line-height:1.35}.meta-row{display:flex;flex-wrap:wrap;gap:14rpx;margin-top:18rpx}.meta-row text{padding:8rpx 14rpx;color:#666;background:#f1f3f4;border-radius:12rpx;font-size:20rpx}.divider{height:1rpx;margin:28rpx 0;background:#eee}.section-title{display:block;color:#111;font-size:28rpx;font-weight:700}.description{display:block;margin-top:14rpx;color:#666;font-size:25rpx;line-height:1.75}.service-card{display:flex;flex-direction:column;gap:20rpx;color:#666;font-size:23rpx}.service-card view{display:flex;align-items:center}.service-icon{display:flex;align-items:center;justify-content:center;width:38rpx;height:38rpx;margin-right:16rpx;color:#18b566;background:#eaf8f0;border-radius:50%;font-size:20rpx}.bottom-space{height:150rpx}.action-bar{position:fixed;right:0;bottom:0;left:0;z-index:20;display:flex;align-items:center;gap:18rpx;padding:16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.96);border-top:1rpx solid #eee}.cart-entry{display:flex;flex-direction:column;align-items:center;justify-content:center;width:112rpx;color:#666;font-size:20rpx}.cart-entry::after,.add-cart::after{border:0}.cart-icon{position:relative}.cart-icon image{width:44rpx;height:44rpx}.cart-icon text{position:absolute;top:-14rpx;right:-22rpx;min-width:34rpx;height:34rpx;padding:0 7rpx;color:#fff;background:#ff4d4f;border-radius:17rpx;font-size:18rpx;line-height:34rpx}.add-cart{display:flex;flex:1;align-items:center;justify-content:center;height:96rpx;color:#fff;background:#18b566;border-radius:28rpx;font-size:29rpx;font-weight:700}.add-cart[disabled]{background:#cfd5d2}
