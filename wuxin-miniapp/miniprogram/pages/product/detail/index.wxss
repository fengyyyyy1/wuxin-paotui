.product-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx 0;
  overflow-x: hidden;
  background: #f6f7f9;
}

.media-card {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}
.media-card image {
  display: block;
  width: 100%;
  aspect-ratio: 1/1;
  background: #f0f2f4;
}
.availability {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  padding: 10rpx 18rpx;
  color: #ffffff;
  background: rgba(17, 17, 17, 0.7);
  border-radius: 14rpx;
  font-size: 22rpx;
  white-space: nowrap;
}
.detail-card,
.service-card {
  width: 100%;
  margin-top: 24rpx;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 32rpx;
}
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}
.price {
  flex-shrink: 0;
  color: #ff8a00;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}
.price-number {
  font-size: 46rpx;
  font-weight: 800;
}
.stock {
  flex-shrink: 0;
  margin-left: 20rpx;
  color: #999999;
  font-size: 22rpx;
  white-space: nowrap;
}
.product-name {
  display: block;
  width: 100%;
  margin-top: 18rpx;
  overflow-wrap: break-word;
  color: #111111;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}
.meta-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}
.meta-row text {
  flex-shrink: 0;
  margin: 0 14rpx 14rpx 0;
  padding: 8rpx 14rpx;
  color: #666666;
  background: #f1f3f4;
  border-radius: 12rpx;
  font-size: 20rpx;
  white-space: nowrap;
}
.divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: #eeeeee;
}
.section-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
}
.description {
  display: block;
  margin-top: 14rpx;
  color: #666666;
  font-size: 25rpx;
  line-height: 1.75;
  overflow-wrap: break-word;
}
.service-card {
  display: flex;
  flex-direction: column;
  color: #666666;
  font-size: 23rpx;
}
.service-card > view {
  display: flex;
  align-items: center;
  min-width: 0;
}
.service-card > view + view {
  margin-top: 20rpx;
}
.service-card > view > text:last-child {
  flex: 1;
  min-width: 0;
}
.service-icon {
  display: flex;
  flex: 0 0 38rpx;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-right: 16rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 50%;
  font-size: 20rpx;
}
.bottom-space {
  height: calc(152rpx + env(safe-area-inset-bottom));
}

.action-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.97);
  border-top: 1rpx solid #eeeeee;
}

.cart-entry {
  display: flex;
  flex: 0 0 156rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  min-width: 156rpx;
  height: 96rpx;
  color: #666666;
}

.cart-entry--pressed {
  opacity: 0.72;
}
.cart-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
}
.cart-icon image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}
.cart-icon text {
  position: absolute;
  top: -14rpx;
  right: -24rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 7rpx;
  color: #ffffff;
  background: #ff4d4f;
  border-radius: 17rpx;
  font-size: 18rpx;
  line-height: 34rpx;
  text-align: center;
  white-space: nowrap;
}
.cart-entry__label {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.2;
  white-space: nowrap;
}
.add-cart {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  margin-left: 18rpx;
  padding: 0 28rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 28rpx;
  font-size: 29rpx;
  font-weight: 700;
  white-space: nowrap;
}
.add-cart::after {
  border: 0;
}
.add-cart[disabled] {
  background: #cfd5d2;
}
