.product-detail-page {
  padding: 0 0 144rpx;
  background: #f5f7fb;
}

.product-hero {
  width: 100%;
  height: 560rpx;
  background: #e2e8f0;
}

.info-card,
.state-card {
  margin: 22rpx 28rpx 0;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.state-card {
  color: #64748b;
  font-size: 26rpx;
  text-align: center;
}

.state-actions {
  display: flex;
  justify-content: center;
  margin-top: 22rpx;
}

.product-name {
  color: #111827;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.35;
}

.price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 20rpx;
}

.price-prefix {
  color: #f97316;
  font-size: 28rpx;
  font-weight: 800;
}

.price {
  color: #f97316;
  font-size: 48rpx;
  font-weight: 900;
}

.status-tag {
  padding: 8rpx 18rpx;
  color: #0f766e;
  background: #d1fae5;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.meta-row {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
  color: #64748b;
  font-size: 24rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.description,
.info-line {
  margin-top: 14rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 28rpx 34rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #e5e7eb;
}

.cart-entry-button {
  position: relative;
  flex: 0 0 auto;
  width: 154rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  color: #0f766e;
  background: #ecfdf5;
  border: 1rpx solid #99f6e4;
  border-radius: 18rpx;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.cart-entry-button::after {
  border: 0;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: 14rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  color: #ffffff;
  background: #f97316;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.cart-action-button {
  flex: 1;
}
