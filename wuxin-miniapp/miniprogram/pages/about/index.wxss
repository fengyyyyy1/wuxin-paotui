.about-page{min-height:100vh;padding:80rpx 32rpx 48rpx;background:#f6f7f9;text-align:center}.brand{display:flex;align-items:center;justify-content:center;width:120rpx;height:120rpx;margin:auto;color:#fff;background:#18b566;border-radius:38rpx;box-shadow:0 18rpx 42rpx rgba(24,181,102,.22);font-size:34rpx;font-weight:800}.name,.version{display:block}.name{margin-top:28rpx;font-size:38rpx;font-weight:800}.version{margin-top:8rpx;color:#999;font-size:22rpx}.about-card{margin-top:34rpx;padding:30rpx;background:#fff;border-radius:32rpx;text-align:left}.card-title,.card-text{display:block}.card-title{font-size:29rpx;font-weight:750}.card-text{margin-top:14rpx;color:#666;font-size:23rpx;line-height:1.7}.about-card view{display:flex;justify-content:space-between;gap:24rpx;margin-bottom:22rpx;color:#666;font-size:23rpx}.about-card view:last-child{margin-bottom:0}.about-card view text:last-child{color:#111;text-align:right}.copyright{display:block;margin-top:64rpx;color:#c1c5c8;font-size:19rpx;letter-spacing:3rpx}
