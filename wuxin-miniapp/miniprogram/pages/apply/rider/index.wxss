.rider-page{min-height:100vh;padding:24rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));background:#f6f7f9}.hero{padding:40rpx 34rpx;color:#fff;background:#111;border-radius:36rpx}.hero-label,.hero-title,.hero-text{display:block}.hero-label{color:#6ee7a8;font-size:22rpx}.hero-title{margin-top:18rpx;font-size:40rpx;font-weight:800;line-height:1.35}.hero-text{margin-top:18rpx;color:rgba(255,255,255,.65);font-size:23rpx;line-height:1.65}.section,.notice{margin-top:22rpx;padding:30rpx;background:#fff;border-radius:32rpx}.section-title{display:block;margin-bottom:26rpx;font-size:29rpx;font-weight:750}.condition{display:flex;gap:20rpx;margin-bottom:24rpx}.condition>text{display:flex;align-items:center;justify-content:center;width:58rpx;height:58rpx;color:#18b566;background:#eaf8f0;border-radius:18rpx;font-size:19rpx;font-weight:700}.condition view{flex:1}.condition view text{display:block}.condition view text:first-child{font-size:25rpx;font-weight:650}.condition view text:last-child{margin-top:7rpx;color:#999;font-size:21rpx;line-height:1.5}.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx}.steps text{padding:20rpx 8rpx;color:#666;background:#f6f7f9;border-radius:18rpx;font-size:21rpx;text-align:center}.notice{background:#fff4e6}.notice text{display:block}.notice text:first-child{color:#d97000;font-size:26rpx;font-weight:700}.notice text:last-child{margin-top:10rpx;color:#8a6338;font-size:22rpx;line-height:1.6}.back{display:flex;align-items:center;justify-content:center;height:96rpx;margin-top:28rpx;color:#fff;background:#18b566;border-radius:28rpx;font-size:28rpx;font-weight:700}.back::after{border:0}
