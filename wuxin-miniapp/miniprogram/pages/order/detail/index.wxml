<view class="detail-page">
  <page-state loading="{{loading}}" error="{{errorMessage}}" empty="{{!loading && !errorMessage && !order}}" empty-title="订单不存在" bind:retry="retry" />
  <block wx:if="{{order}}">
    <view class="status-hero status-{{statusTone}}"><text class="status-title">{{order.payStatus === 0 && order.status === 0 ? '等待付款' : order.statusText}}</text><text class="status-caption">订单状态更新后会在这里同步展示</text><text class="order-no">{{order.orderNo}}</text></view>
    <view wx:if="{{address}}" class="address-card"><view class="address-icon">址</view><view class="address-copy"><text class="contact">{{address.receiverName}} · {{address.maskedPhone}}</text><text class="address-text">{{address.fullAddress}}</text></view></view>
    <view class="goods-card"><view class="card-title"><text>{{order.storeName || '订单商品'}}</text><text>{{items.length}} 种商品</text></view><view class="goods-item" wx:for="{{items}}" wx:key="productId"><image src="{{item.imageUrl}}" mode="aspectFill" data-id="{{item.productId}}" binderror="handleImageError" /><view class="goods-copy"><text class="goods-name">{{item.productName}}</text><text class="goods-price">¥{{item.priceText}} × {{item.quantity}}</text></view><text class="subtotal">¥{{item.subtotalText}}</text></view><view wx:if="{{!items.length}}" class="legacy-goods">{{order.goodsName || order.goodsDescription || '跑腿服务订单'}}</view></view>
    <view class="amount-card"><view><text>商品金额</text><text>¥{{productAmountText}}</text></view><view><text>配送费</text><text>¥{{deliveryFeeText}}</text></view><view class="total"><text>订单金额</text><text>¥{{amountText}}</text></view></view>
    <view class="info-card"><view><text>下单时间</text><text>{{createTimeText}}</text></view><view><text>支付状态</text><text>{{order.payStatusText}}</text></view><view wx:if="{{order.remark}}"><text>订单备注</text><text>{{order.remark}}</text></view></view>
    <view wx:if="{{timeline.length}}" class="timeline-card"><text class="timeline-title">订单进度</text><view class="timeline-item" wx:for="{{timeline}}" wx:key="sort"><view class="timeline-axis"><text class="dot"></text><text wx:if="{{index < timeline.length - 1}}" class="line"></text></view><view class="timeline-copy"><text class="event-title">{{item.title}}</text><text wx:if="{{item.description}}" class="event-description">{{item.description}}</text><text class="event-time">{{item.timeText}}</text></view></view></view>
    <view wx:if="{{canPay || canCancel || canConfirm}}" class="bottom-space"></view><view wx:if="{{canPay || canCancel || canConfirm}}" class="action-bar"><button wx:if="{{canCancel}}" class="secondary" loading="{{operating}}" bindtap="cancelOrder">取消订单</button><button wx:if="{{canPay}}" class="primary" bindtap="payOrder">立即支付</button><button wx:if="{{canConfirm}}" class="primary" loading="{{operating}}" bindtap="confirmReceipt">确认收货</button></view>
  </block>
</view>
