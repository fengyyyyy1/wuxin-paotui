.detail-page{min-height:100vh;padding:24rpx 32rpx 48rpx;background:#f6f7f9}.status-hero{padding:36rpx;color:#fff;background:#18b566;border-radius:36rpx}.status-warning{background:#ff8a00}.status-muted{background:#7b8389}.status-title,.status-caption,.order-no{display:block}.status-title{font-size:38rpx;font-weight:800}.status-caption{margin-top:10rpx;color:rgba(255,255,255,.82);font-size:23rpx}.order-no{margin-top:26rpx;color:rgba(255,255,255,.72);font-size:20rpx}.address-card,.goods-card,.amount-card,.info-card,.timeline-card{margin-top:20rpx;padding:28rpx;background:#fff;border-radius:32rpx}.address-card{display:flex;align-items:center;gap:20rpx}.address-icon{display:flex;flex-shrink:0;align-items:center;justify-content:center;width:70rpx;height:70rpx;color:#18b566;background:#eaf8f0;border-radius:22rpx;font-size:23rpx;font-weight:700}.contact,.address-text{display:block}.contact{font-size:26rpx;font-weight:700}.address-text{margin-top:8rpx;color:#666;font-size:22rpx;line-height:1.5}.card-title{display:flex;align-items:center;justify-content:space-between;padding-bottom:20rpx;border-bottom:1rpx solid #eee}.card-title text:first-child{font-size:28rpx;font-weight:700}.card-title text:last-child{color:#999;font-size:20rpx}.goods-item{display:flex;align-items:center;gap:18rpx;padding:20rpx 0;border-bottom:1rpx solid #eee}.goods-item image{width:112rpx;height:112rpx;background:#f0f2f4;border-radius:18rpx}.goods-item view{flex:1;min-width:0}.goods-name,.goods-price{display:block}.goods-name{overflow:hidden;font-size:25rpx;font-weight:650;text-overflow:ellipsis;white-space:nowrap}.goods-price{margin-top:10rpx;color:#999;font-size:20rpx}.subtotal{font-size:23rpx;font-weight:650}.legacy-goods{padding:24rpx 0;color:#666;font-size:24rpx}.amount-card view,.info-card view{display:flex;justify-content:space-between;gap:30rpx;margin-bottom:20rpx;color:#666;font-size:23rpx}.amount-card view:last-child,.info-card view:last-child{margin-bottom:0}.amount-card .total{padding-top:20rpx;color:#111;border-top:1rpx solid #eee;font-weight:650}.amount-card .total text:last-child{color:#ff8a00;font-size:31rpx;font-weight:800}.info-card view text:last-child{max-width:430rpx;color:#111;text-align:right}.timeline-title{display:block;margin-bottom:26rpx;font-size:28rpx;font-weight:700}.timeline-item{display:flex;gap:20rpx}.timeline-axis{position:relative;width:20rpx}.dot{position:relative;z-index:2;display:block;width:18rpx;height:18rpx;background:#18b566;border:5rpx solid #dff5e9;border-radius:50%}.line{position:absolute;top:25rpx;bottom:-4rpx;left:8rpx;width:2rpx;background:#dff5e9}.timeline-copy{padding-bottom:30rpx}.event-title,.event-description,.event-time{display:block}.event-title{font-size:25rpx;font-weight:650}.event-description{margin-top:8rpx;color:#666;font-size:21rpx}.event-time{margin-top:8rpx;color:#999;font-size:19rpx}.bottom-space{height:120rpx}.action-bar{position:fixed;right:0;bottom:0;left:0;display:flex;justify-content:flex-end;gap:16rpx;padding:16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.97);border-top:1rpx solid #eee}.action-bar button{display:flex;align-items:center;justify-content:center;min-width:190rpx;height:86rpx;padding:0 28rpx;border-radius:26rpx;font-size:26rpx;font-weight:650}.action-bar button::after{border:0}.secondary{color:#ff4d4f;background:#fff1f1}.primary{color:#fff;background:#18b566}
