.orders-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  overflow-x: hidden;
  background: #f6f7f9;
}
.heading {
  margin: 12rpx 0 24rpx;
}
.title,
.subtitle {
  display: block;
}
.title {
  font-size: 44rpx;
  font-weight: 800;
}
.subtitle {
  margin-top: 8rpx;
  color: #999;
  font-size: 23rpx;
}
.tabs {
  width: 100%;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.tab-row {
  display: inline-flex;
  min-width: 100%;
  padding-right: 4rpx;
  white-space: nowrap;
}
.tab {
  flex-shrink: 0;
  padding: 17rpx 26rpx;
  color: #666;
  background: #fff;
  border-radius: 26rpx;
  font-size: 24rpx;
  white-space: nowrap;
}
.tab + .tab {
  margin-left: 14rpx;
}
.tab.active {
  color: #fff;
  background: #18b566;
}
.order-list {
  width: 100%;
}
.order-card {
  width: 100%;
  min-width: 0;
  padding: 28rpx;
  overflow: hidden;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
}
.order-card + .order-card {
  margin-top: 20rpx;
}
.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-width: 0;
}
.order-top__copy {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.order-no,
.order-time {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.order-no {
  font-size: 24rpx;
  font-weight: 650;
}
.order-time {
  margin-top: 8rpx;
  color: #999;
  font-size: 20rpx;
}
.status {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  white-space: nowrap;
}
.status-brand {
  color: #18b566;
  background: #eaf8f0;
}
.status-warning {
  color: #d97000;
  background: #fff4e6;
}
.status-success {
  color: #18b566;
  background: #eaf8f0;
}
.status-muted {
  color: #999;
  background: #f1f3f4;
}
.order-summary {
  display: flex;
  align-items: center;
  min-width: 0;
  margin-top: 24rpx;
  padding: 20rpx;
  overflow: hidden;
  background: #f7f8f9;
  border-radius: 24rpx;
}
.summary-icon {
  display: flex;
  flex: 0 0 76rpx;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin-right: 18rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.summary-copy {
  flex: 1;
  min-width: 0;
}
.summary-copy text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.summary-copy text:first-child {
  font-size: 25rpx;
  font-weight: 650;
}
.summary-copy text:last-child {
  margin-top: 7rpx;
  color: #999;
  font-size: 20rpx;
}
.amount {
  flex-shrink: 0;
  margin-left: 18rpx;
  text-align: right;
  white-space: nowrap;
}
.amount text {
  display: block;
}
.amount text:first-child {
  color: #999;
  font-size: 19rpx;
}
.amount text:last-child {
  margin-top: 6rpx;
  color: #ff8a00;
  font-size: 27rpx;
  font-weight: 750;
}
.order-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  margin-top: 22rpx;
}
.order-actions button {
  flex-shrink: 0;
  margin: 0 0 10rpx 14rpx;
  padding: 15rpx 24rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  white-space: nowrap;
}
.order-actions button::after {
  border: 0;
}
.detail {
  color: #666;
  background: #f1f3f4;
}
.secondary {
  color: #ff4d4f;
  background: #fff1f1;
}
.primary {
  color: #fff;
  background: #18b566;
}
