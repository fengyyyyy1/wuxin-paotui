.orders-page{min-height:100vh;padding:24rpx 32rpx 48rpx;background:#f6f7f9}.heading{margin:12rpx 0 24rpx}.title,.subtitle{display:block}.title{font-size:44rpx;font-weight:800}.subtitle{margin-top:8rpx;color:#999;font-size:23rpx}.tabs{width:calc(100% + 32rpx);margin-bottom:24rpx}.tab-row{display:flex;gap:14rpx;padding-right:32rpx}.tab{flex-shrink:0;padding:17rpx 26rpx;color:#666;background:#fff;border-radius:26rpx;font-size:24rpx}.tab::after{border:0}.tab.active{color:#fff;background:#18b566}.order-list{display:flex;flex-direction:column;gap:20rpx}.order-card{padding:28rpx;background:#fff;border-radius:32rpx;box-shadow:0 8rpx 30rpx rgba(0,0,0,.04)}.order-top{display:flex;align-items:flex-start;justify-content:space-between;gap:16rpx}.order-no,.order-time{display:block}.order-no{font-size:24rpx;font-weight:650}.order-time{margin-top:8rpx;color:#999;font-size:20rpx}.status{flex-shrink:0;padding:8rpx 14rpx;border-radius:12rpx;font-size:20rpx}.status-brand{color:#18b566;background:#eaf8f0}.status-warning{color:#d97000;background:#fff4e6}.status-success{color:#18b566;background:#eaf8f0}.status-muted{color:#999;background:#f1f3f4}.order-summary{display:flex;align-items:center;gap:18rpx;margin-top:24rpx;padding:20rpx;background:#f7f8f9;border-radius:24rpx}.summary-icon{display:flex;align-items:center;justify-content:center;width:76rpx;height:76rpx;color:#18b566;background:#eaf8f0;border-radius:22rpx;font-size:24rpx;font-weight:700}.summary-copy{flex:1;min-width:0}.summary-copy text{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.summary-copy text:first-child{font-size:25rpx;font-weight:650}.summary-copy text:last-child{margin-top:7rpx;color:#999;font-size:20rpx}.amount{text-align:right}.amount text{display:block}.amount text:first-child{color:#999;font-size:19rpx}.amount text:last-child{margin-top:6rpx;color:#ff8a00;font-size:27rpx;font-weight:750}.order-actions{display:flex;justify-content:flex-end;gap:14rpx;margin-top:22rpx}.order-actions button{padding:15rpx 24rpx;border-radius:22rpx;font-size:22rpx}.order-actions button::after{border:0}.detail{color:#666;background:#f1f3f4}.secondary{color:#ff4d4f;background:#fff1f1}.primary{color:#fff;background:#18b566}
