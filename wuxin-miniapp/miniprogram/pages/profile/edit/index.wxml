<view class="edit-page">
  <text class="title">编辑个人资料</text><text class="subtitle">保持资料真实，让服务更贴近你</text>
  <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>
  <view class="form-card">
    <view class="field"><text class="label">昵称</text><input value="{{nickname}}" maxlength="30" placeholder="未填写时显示微信用户" bindinput="onNicknameChange" /></view>
    <view class="field"><text class="label">头像 URL</text><input value="{{avatar}}" maxlength="255" placeholder="请输入 HTTPS 图片地址" bindinput="onAvatarChange" /><text class="hint">暂不上传图片，留空使用平台默认头像</text></view>
    <view class="field"><text class="label">性别</text><radio-group class="gender-row" bindchange="onGenderChange"><label class="gender {{gender === 0 ? 'active' : ''}}"><radio value="0" checked="{{gender === 0}}" color="#18B566" />保密</label><label class="gender {{gender === 1 ? 'active' : ''}}"><radio value="1" checked="{{gender === 1}}" color="#18B566" />男</label><label class="gender {{gender === 2 ? 'active' : ''}}"><radio value="2" checked="{{gender === 2}}" color="#18B566" />女</label></radio-group></view>
  </view>
  <button class="save" loading="{{saving}}" disabled="{{saving}}" bindtap="submitProfile">保存资料</button>
</view>
