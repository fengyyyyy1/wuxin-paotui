<view class="profile-page">
  <view class="user-card">
    <image class="user-avatar" src="{{avatarUrl}}" mode="aspectFill" binderror="handleAvatarError" />
    <view class="user-copy">
      <text class="user-name">{{displayName}}</text>
      <text class="user-username">{{usernameText}}</text>
      <text class="user-phone">{{phoneText}}</text>
    </view>
    <view class="user-edit" hover-class="user-edit--pressed" bindtap="goToEditProfile">编辑资料 ›</view>
  </view>

  <view class="order-card">
    <view class="order-heading">
      <text class="order-heading__title">我的订单</text>
      <view class="order-heading__action" bindtap="goToOrders">全部订单 ›</view>
    </view>
    <view class="order-entries">
      <view class="order-entry" bindtap="goToOrders"><text class="order-icon">付</text><text class="order-label">待付款</text></view>
      <view class="order-entry" bindtap="goToOrders"><text class="order-icon">接</text><text class="order-label">待接单</text></view>
      <view class="order-entry" bindtap="goToOrders"><text class="order-icon">送</text><text class="order-label">配送中</text></view>
      <view class="order-entry" bindtap="goToOrders"><text class="order-icon">成</text><text class="order-label">已完成</text></view>
    </view>
  </view>

  <view class="menu-card">
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToAddressList"><text class="menu-icon green">址</text><text class="menu-label">地址管理</text><text class="menu-value">常用收送地址</text><text class="menu-arrow">›</text></button>
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToCart"><text class="menu-icon orange">篮</text><text class="menu-label">购物车</text><text wx:if="{{cartCount}}" class="menu-badge">{{cartCount}}</text><text wx:else class="menu-value">已选商品</text><text class="menu-arrow">›</text></button>
    <button class="menu-row phone-row" hover-class="menu-row--pressed" open-type="{{phoneBindOpenType}}" disabled="{{!canBindPhone || bindingPhone}}" bindtap="handleBindPhoneClick" bindgetphonenumber="handleGetPhoneNumber"><text class="menu-icon blue">机</text><text class="menu-label">手机号</text><text class="menu-value">{{phoneButtonText}}</text><text wx:if="{{canBindPhone}}" class="menu-arrow">›</text></button>
  </view>

  <view class="menu-card">
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToMerchantApply"><text class="menu-icon green">商</text><text class="menu-label">商家入驻</text><text class="menu-value">提交入驻资料</text><text class="menu-arrow">›</text></button>
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToRiderApply"><text class="menu-icon orange">骑</text><text class="menu-label">申请成为骑手</text><text class="menu-value">加入配送团队</text><text class="menu-arrow">›</text></button>
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToPublic"><text class="menu-icon blue">益</text><text class="menu-label">公益服务</text><text class="menu-value">安全与公益指引</text><text class="menu-arrow">›</text></button>
  </view>

  <view class="menu-card">
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToAbout"><text class="menu-icon gray">五</text><text class="menu-label">关于五鑫</text><text class="menu-value">了解平台</text><text class="menu-arrow">›</text></button>
    <button class="menu-row" hover-class="menu-row--pressed" bindtap="goToSettings"><text class="menu-icon gray">设</text><text class="menu-label">设置</text><text class="menu-arrow">›</text></button>
  </view>
</view>
