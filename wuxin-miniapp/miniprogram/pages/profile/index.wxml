<view class="profile-page">
  <view class="user-card">
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" binderror="handleAvatarError" />
    <view class="user-copy"><text class="name">{{displayName}}</text><text class="username">{{usernameText}}</text><text class="phone">{{phoneText}}</text></view>
    <button class="edit" bindtap="goToEditProfile">编辑资料 ›</button>
  </view>

  <view class="order-card"><view class="section-title"><text>我的订单</text><button bindtap="goToOrders">全部订单 ›</button></view><view class="order-grid"><button bindtap="goToOrders"><text class="order-icon">付</text><text>待付款</text></button><button bindtap="goToOrders"><text class="order-icon">接</text><text>待接单</text></button><button bindtap="goToOrders"><text class="order-icon">送</text><text>配送中</text></button><button bindtap="goToOrders"><text class="order-icon">成</text><text>已完成</text></button></view></view>

  <view class="menu-card">
    <button bindtap="goToAddressList"><text class="menu-icon green">址</text><text>地址管理</text><text class="arrow">›</text></button>
    <button bindtap="goToCart"><text class="menu-icon orange">篮</text><text>购物车</text><text wx:if="{{cartCount}}" class="badge">{{cartCount}}</text><text class="arrow">›</text></button>
    <button class="phone-row" open-type="{{phoneBindOpenType}}" disabled="{{!canBindPhone || bindingPhone}}" bindtap="handleBindPhoneClick" bindgetphonenumber="handleGetPhoneNumber"><text class="menu-icon blue">机</text><text>手机号</text><text class="menu-value">{{phoneButtonText}}</text><text wx:if="{{canBindPhone}}" class="arrow">›</text></button>
  </view>

  <view class="menu-card">
    <button bindtap="goToMerchantApply"><text class="menu-icon green">商</text><text>商家入驻</text><text class="arrow">›</text></button>
    <button bindtap="goToRiderApply"><text class="menu-icon orange">骑</text><text>申请成为骑手</text><text class="arrow">›</text></button>
    <button bindtap="goToPublic"><text class="menu-icon blue">益</text><text>公益服务</text><text class="arrow">›</text></button>
  </view>

  <view class="menu-card"><button bindtap="goToAbout"><text class="menu-icon gray">五</text><text>关于五鑫</text><text class="arrow">›</text></button><button bindtap="goToSettings"><text class="menu-icon gray">设</text><text>设置</text><text class="arrow">›</text></button></view>
</view>
