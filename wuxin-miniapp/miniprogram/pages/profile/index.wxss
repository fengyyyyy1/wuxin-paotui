.profile-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  overflow-x: hidden;
  background: #f6f7f9;
}

.user-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 32rpx;
  overflow: hidden;
  background: #111111;
  border-radius: 36rpx;
  box-shadow: 0 14rpx 38rpx rgba(0, 0, 0, 0.14);
}

.user-avatar {
  display: block;
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 112rpx;
  background: #e8ebed;
  border: 5rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 36rpx;
}
.user-copy {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
  overflow: hidden;
  color: #ffffff;
}
.user-name,
.user-username,
.user-phone {
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.user-name {
  font-size: 34rpx;
  font-weight: 800;
}
.user-username {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 20rpx;
}
.user-phone {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}
.user-edit {
  flex: 0 0 auto;
  min-width: 104rpx;
  margin-left: 16rpx;
  padding: 14rpx 0;
  color: rgba(255, 255, 255, 0.72);
  font-size: 21rpx;
  text-align: right;
  white-space: nowrap;
}
.user-edit--pressed {
  opacity: 0.65;
}

.order-card,
.menu-card {
  width: 100%;
  margin-top: 22rpx;
  background: #ffffff;
  border-radius: 32rpx;
}
.order-card {
  padding: 28rpx;
}
.order-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
}
.order-heading__title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  font-size: 29rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.order-heading__action {
  flex-shrink: 0;
  margin-left: 20rpx;
  padding: 8rpx 0;
  color: #999999;
  font-size: 21rpx;
  white-space: nowrap;
}

.order-entries {
  display: flex;
  align-items: stretch;
  width: 100%;
  margin-top: 28rpx;
}
.order-entry {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  padding: 4rpx;
  color: #666666;
}
.order-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 22rpx;
  font-size: 23rpx;
  font-weight: 700;
}
.order-label {
  display: block;
  width: 100%;
  margin-top: 11rpx;
  overflow: hidden;
  font-size: 21rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-card {
  padding: 6rpx 28rpx;
  overflow: hidden;
}
.menu-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  min-height: 100rpx;
  padding: 0;
  color: #111111;
  background: transparent;
  border-bottom: 1rpx solid #eeeeee;
  font-size: 26rpx;
  text-align: left;
}
.menu-row:last-child {
  border-bottom: 0;
}
.menu-row::after {
  border: 0;
}
.menu-icon {
  display: flex;
  flex: 0 0 58rpx;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin-right: 20rpx;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 700;
}
.menu-label {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.green {
  color: #18b566;
  background: #eaf8f0;
}
.orange {
  color: #e87400;
  background: #fff4e6;
}
.blue {
  color: #3478d4;
  background: #eaf3ff;
}
.gray {
  color: #666666;
  background: #f0f2f4;
}
.menu-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  color: #bbbbbb;
  font-size: 31rpx;
  white-space: nowrap;
}
.menu-badge {
  flex-shrink: 0;
  min-width: 38rpx;
  height: 38rpx;
  margin-left: 12rpx;
  padding: 0 8rpx;
  color: #ffffff;
  background: #ff4d4f;
  border-radius: 19rpx;
  font-size: 19rpx;
  line-height: 38rpx;
  text-align: center;
  white-space: nowrap;
}
.menu-value {
  flex-shrink: 0;
  max-width: 210rpx;
  margin-left: 12rpx;
  overflow: hidden;
  color: #999999;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.phone-row[disabled] {
  opacity: 1;
}
