.profile-page{min-height:100vh;padding:24rpx 32rpx 48rpx;background:#f6f7f9}.user-card{display:flex;align-items:center;padding:34rpx;background:#111;border-radius:36rpx;box-shadow:0 14rpx 38rpx rgba(0,0,0,.14)}.avatar{flex-shrink:0;width:118rpx;height:118rpx;background:#e8ebed;border:5rpx solid rgba(255,255,255,.18);border-radius:38rpx}.user-copy{flex:1;min-width:0;margin-left:24rpx;color:#fff}.name,.username,.phone{display:block}.name{overflow:hidden;font-size:34rpx;font-weight:800;text-overflow:ellipsis;white-space:nowrap}.username{margin-top:7rpx;color:rgba(255,255,255,.55);font-size:20rpx}.phone{margin-top:10rpx;color:rgba(255,255,255,.78);font-size:23rpx}.edit{flex-shrink:0;padding:12rpx;color:rgba(255,255,255,.72);font-size:21rpx}.edit::after{border:0}.order-card,.menu-card{margin-top:22rpx;padding:28rpx;background:#fff;border-radius:32rpx}.section-title{display:flex;align-items:center;justify-content:space-between}.section-title text{font-size:29rpx;font-weight:700}.section-title button{color:#999;font-size:21rpx}.section-title button::after{border:0}.order-grid{display:grid;grid-template-columns:repeat(4,1fr);margin-top:28rpx}.order-grid button{display:flex;flex-direction:column;align-items:center;color:#666;font-size:21rpx}.order-grid button::after{border:0}.order-icon{display:flex;align-items:center;justify-content:center;width:68rpx;height:68rpx;margin-bottom:11rpx;color:#18b566;background:#eaf8f0;border-radius:22rpx;font-size:23rpx;font-weight:700}.menu-card{padding:6rpx 28rpx}.menu-card>button{display:flex;align-items:center;width:100%;min-height:100rpx;color:#111;background:transparent;border-bottom:1rpx solid #eee;font-size:26rpx;text-align:left}.menu-card>button:last-child{border-bottom:0}.menu-card>button::after{border:0}.menu-icon{display:flex;flex-shrink:0;align-items:center;justify-content:center;width:58rpx;height:58rpx;margin-right:20rpx;border-radius:18rpx;font-size:20rpx;font-weight:700}.green{color:#18b566;background:#eaf8f0}.orange{color:#e87400;background:#fff4e6}.blue{color:#3478d4;background:#eaf3ff}.gray{color:#666;background:#f0f2f4}.arrow{margin-left:auto;color:#bbb;font-size:31rpx}.badge{margin-left:auto;min-width:38rpx;height:38rpx;padding:0 8rpx;color:#fff;background:#ff4d4f;border-radius:19rpx;font-size:19rpx;line-height:38rpx;text-align:center}.menu-value{margin-left:auto;color:#999;font-size:22rpx}.phone-row[disabled]{opacity:1}
