<view class="form-page">
  <text class="page-title">{{mode === 'edit' ? '编辑地址' : '新增地址'}}</text>
  <text class="page-subtitle">请填写真实配送信息，便于骑手准确送达</text>
  <view wx:if="{{errorMessage}}" class="error-banner">{{errorMessage}}</view>
  <view class="form-card">
    <view class="field-group"><text class="label">收件人</text><input value="{{receiverName}}" maxlength="30" placeholder="请输入收件人姓名" bindinput="onReceiverNameChange" /></view>
    <view class="field-group"><text class="label">手机号</text><input value="{{receiverPhone}}" maxlength="11" type="number" placeholder="请输入11位手机号" bindinput="onReceiverPhoneChange" /></view>
    <view class="region-row"><view class="field-group"><text class="label">省</text><input value="{{province}}" maxlength="30" placeholder="省份" bindinput="onProvinceChange" /></view><view class="field-group"><text class="label">市</text><input value="{{city}}" maxlength="30" placeholder="城市" bindinput="onCityChange" /></view><view class="field-group"><text class="label">区/县</text><input value="{{district}}" maxlength="30" placeholder="区县" bindinput="onDistrictChange" /></view></view>
    <view class="field-group"><view class="label-row"><text class="label">详细地址</text><button bindtap="chooseLocation">地图选择 ›</button></view><textarea value="{{detailAddress}}" maxlength="120" placeholder="街道、楼栋、门牌号" auto-height bindinput="onDetailAddressChange" /></view>
    <view class="default-row"><view><text class="default-title">设为默认地址</text><text class="default-caption">下单时优先使用此地址</text></view><switch checked="{{isDefault}}" color="#18B566" bindchange="onDefaultChange" /></view>
  </view>
  <button class="save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="submitAddress">{{saving ? '正在保存' : '保存地址'}}</button>
</view>
