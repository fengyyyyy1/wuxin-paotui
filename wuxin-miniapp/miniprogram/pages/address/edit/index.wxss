.form-page {
  width: 100%;
  min-height: 100vh;
  padding: 30rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: #f6f7f9;
}
.page-title,
.page-subtitle {
  display: block;
}
.page-title {
  font-size: 44rpx;
  font-weight: 800;
}
.page-subtitle {
  margin-top: 8rpx;
  color: #999;
  font-size: 23rpx;
}
.error-banner {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  color: #c73335;
  background: #fff1f1;
  border-radius: 20rpx;
  font-size: 23rpx;
}
.form-card {
  margin-top: 28rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 32rpx;
}
.field-group {
  flex: 1;
  min-width: 0;
  margin-bottom: 28rpx;
}
.label {
  display: block;
  margin-bottom: 12rpx;
  color: #666;
  font-size: 23rpx;
  font-weight: 600;
}
.field-group input,
.field-group textarea {
  width: 100%;
  min-height: 88rpx;
  padding: 0 22rpx;
  color: #111;
  background: #f6f7f9;
  border-radius: 22rpx;
  font-size: 26rpx;
}
.field-group textarea {
  min-height: 140rpx;
  padding: 22rpx;
  line-height: 1.55;
}
.region-row {
  display: flex;
}
.region-row .field-group + .field-group {
  margin-left: 14rpx;
}
.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.label-row button {
  margin-bottom: 10rpx;
  padding: 6rpx;
  color: #18b566;
  font-size: 22rpx;
}
.label-row button::after {
  border: 0;
}
.default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}
.default-title,
.default-caption {
  display: block;
}
.default-title {
  font-size: 27rpx;
  font-weight: 650;
}
.default-caption {
  margin-top: 7rpx;
  color: #999;
  font-size: 21rpx;
}
.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 98rpx;
  margin-top: 28rpx;
  color: #fff;
  background: #18b566;
  border-radius: 28rpx;
  font-size: 29rpx;
  font-weight: 700;
}
.save-button::after {
  border: 0;
}
.save-button[disabled] {
  opacity: 0.65;
}
