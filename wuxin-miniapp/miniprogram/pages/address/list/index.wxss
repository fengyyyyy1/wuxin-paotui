.address-page {
  padding-bottom: 152rpx;
}

.address-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.error-card,
.loading-card,
.empty-card,
.address-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.error-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: #dc2626;
  font-size: 26rpx;
}

.loading-card {
  color: #64748b;
  font-size: 26rpx;
  text-align: center;
}

.address-card-default {
  border-color: rgba(15, 118, 110, 0.32);
}

.address-main {
  margin-bottom: 24rpx;
}

.receiver-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.receiver-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.receiver-phone {
  color: #475569;
  font-size: 26rpx;
}

.default-tag {
  padding: 4rpx 12rpx;
  color: #0f766e;
  background: rgba(15, 118, 110, 0.1);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.address-text {
  color: #334155;
  font-size: 27rpx;
  line-height: 1.6;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.address-action {
  min-width: 116rpx;
  padding: 12rpx 18rpx;
  color: #334155;
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.3;
  text-align: center;
}

.address-action-primary {
  color: #0f766e;
  border-color: rgba(15, 118, 110, 0.36);
}

.address-action-danger {
  color: #dc2626;
  border-color: rgba(220, 38, 38, 0.34);
}

.fixed-action {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  left: 32rpx;
  z-index: 10;
}
