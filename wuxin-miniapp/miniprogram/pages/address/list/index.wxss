.address-page{min-height:100vh;padding:24rpx 32rpx 0;background:#f6f7f9}.page-heading{margin:12rpx 0 28rpx}.title,.subtitle{display:block}.title{font-size:44rpx;font-weight:800}.subtitle{margin-top:8rpx;color:#999;font-size:23rpx}.address-list{display:flex;flex-direction:column;gap:20rpx}.address-card{padding:28rpx;background:#fff;border-radius:32rpx;box-shadow:0 8rpx 30rpx rgba(0,0,0,.04);transition:transform 160ms ease}.address-card:active{transform:scale(.99)}.address-top{display:flex;align-items:center;justify-content:space-between}.contact{display:flex;align-items:center;gap:14rpx}.name{font-size:29rpx;font-weight:700}.phone{color:#666;font-size:24rpx}.default-tag{padding:6rpx 12rpx;color:#18b566;background:#eaf8f0;border-radius:10rpx;font-size:19rpx}.select-arrow{color:#aaa;font-size:34rpx}.full-address{display:block;margin-top:18rpx;color:#333;font-size:26rpx;line-height:1.55}.address-actions{display:flex;align-items:center;justify-content:space-between;margin-top:24rpx;padding-top:20rpx;border-top:1rpx solid #eee}.address-actions button{padding:8rpx;color:#666;font-size:22rpx}.address-actions button::after{border:0}.action-right{display:flex;gap:22rpx}.address-actions .delete{color:#ff4d4f}.bottom-space{height:140rpx}.add-bar{position:fixed;right:0;bottom:0;left:0;padding:16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.96);border-top:1rpx solid #eee}.add-address{display:flex;align-items:center;justify-content:center;height:96rpx;color:#fff;background:#18b566;border-radius:28rpx;font-size:29rpx;font-weight:700}.add-address::after{border:0}
