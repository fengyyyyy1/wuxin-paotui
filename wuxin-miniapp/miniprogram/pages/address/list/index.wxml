<view class="page address-page">
  <view class="section address-header">
    <view>
      <view class="title">地址管理</view>
      <view class="subtitle">管理收货地址，后续商品订单将直接复用。</view>
    </view>
    <van-button size="small" loading="{{ loading }}" bind:click="loadAddresses">刷新</van-button>
  </view>

  <view wx:if="{{ errorMessage }}" class="error-card">
    <view>{{ errorMessage }}</view>
    <van-button size="small" type="primary" bind:click="loadAddresses">重新加载</van-button>
  </view>

  <view wx:if="{{ loading && !addresses.length }}" class="loading-card">地址加载中...</view>

  <block wx:elif="{{ addresses.length }}">
    <view
      wx:for="{{ addresses }}"
      wx:key="id"
      class="address-card {{ item.isDefault === 1 ? 'address-card-default' : '' }}"
    >
      <view class="address-main">
        <view class="receiver-row">
          <view class="receiver-name">{{ item.receiverName }}</view>
          <view class="receiver-phone">{{ item.maskedPhone }}</view>
          <view wx:if="{{ item.isDefault === 1 }}" class="default-tag">默认</view>
        </view>
        <view class="address-text">{{ item.fullAddress }}</view>
      </view>
      <view class="address-actions">
        <view class="address-action address-action-primary" bindtap="editAddress" data-id="{{ item.id }}">编辑</view>
        <view
          wx:if="{{ item.isDefault !== 1 }}"
          class="address-action"
          bindtap="setDefaultAddress"
          data-id="{{ item.id }}"
        >
          设为默认
        </view>
        <view
          class="address-action address-action-danger"
          bindtap="confirmDeleteAddress"
          data-id="{{ item.id }}"
        >
          {{ deletingId === item.id ? '删除中' : '删除' }}
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-card">
    <empty-state title="暂无地址数据" description="添加常用收货地址，后续下单会更顺手。" />
  </view>

  <view class="fixed-action">
    <van-button type="primary" block bind:click="goToCreateAddress">新增地址</van-button>
  </view>
</view>
