.result-page{min-height:100vh;padding:110rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));background:#f6f7f9;text-align:center}.result-icon{display:flex;align-items:center;justify-content:center;width:124rpx;height:124rpx;margin:0 auto;color:#ff4d4f;background:#fff1f1;border-radius:40rpx;font-size:58rpx;font-weight:800}.result-title{display:block;margin-top:36rpx;font-size:40rpx;font-weight:800}.result-text{display:block;margin-top:12rpx;color:#999;font-size:24rpx}.tip-card{margin-top:48rpx;padding:30rpx;background:#fff;border-radius:32rpx}.tip-card text{display:block}.tip-card text:first-child{font-size:28rpx;font-weight:700}.tip-card text:last-child{margin-top:12rpx;color:#999;font-size:23rpx;line-height:1.6}.primary,.secondary{display:flex;align-items:center;justify-content:center;height:96rpx;border-radius:28rpx;font-size:28rpx;font-weight:700}.primary{margin-top:48rpx;color:#fff;background:#18b566}.secondary{margin-top:18rpx;color:#18b566;background:#eaf8f0}.primary::after,.secondary::after,.link::after{border:0}.link{margin:26rpx auto 0;color:#999;font-size:23rpx}
