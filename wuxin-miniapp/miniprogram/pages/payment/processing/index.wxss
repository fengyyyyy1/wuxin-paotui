.status-page{display:flex;min-height:100vh;flex-direction:column;align-items:center;justify-content:center;padding:64rpx;background:#fff;text-align:center}.pay-spinner{width:82rpx;height:82rpx;border:7rpx solid #dff5e9;border-top-color:#18b566;border-radius:50%;animation:spin .8s linear infinite}.status-title{margin-top:40rpx;font-size:34rpx;font-weight:750}.status-text{margin-top:14rpx;color:#999;font-size:23rpx}@keyframes spin{to{transform:rotate(360deg)}}
