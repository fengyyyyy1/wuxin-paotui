<view class="result-page"><view class="result-icon">✓</view><text class="result-title">支付成功</text><text class="result-text">订单已经进入处理流程</text><view wx:if="{{payment}}" class="payment-card"><view><text>支付金额</text><text class="amount">¥{{amountText}}</text></view><view><text>订单编号</text><text>{{payment.orderNo}}</text></view><view wx:if="{{successTimeText}}"><text>支付时间</text><text>{{successTimeText}}</text></view></view><button class="primary" bindtap="viewOrder">查看订单</button><button class="secondary" bindtap="backHome">返回首页</button></view>
