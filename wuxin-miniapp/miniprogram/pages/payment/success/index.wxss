.result-page {
  width: 100%;
  min-height: 100vh;
  padding: 110rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: #f6f7f9;
  text-align: center;
}
.result-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 124rpx;
  margin: 0 auto;
  color: #fff;
  background: #18b566;
  border-radius: 40rpx;
  box-shadow: 0 18rpx 44rpx rgba(24, 181, 102, 0.25);
  font-size: 58rpx;
}
.result-title {
  display: block;
  margin-top: 36rpx;
  font-size: 40rpx;
  font-weight: 800;
}
.result-text {
  display: block;
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}
.payment-card {
  margin-top: 48rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  text-align: left;
}
.payment-card view {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
  color: #666;
  font-size: 23rpx;
}
.payment-card view text:first-child {
  flex-shrink: 0;
}
.payment-card view:last-child {
  margin-bottom: 0;
}
.payment-card text:last-child {
  max-width: 420rpx;
  overflow: hidden;
  color: #111;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.payment-card .amount {
  color: #ff8a00;
  font-size: 30rpx;
  font-weight: 750;
}
.primary,
.secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 700;
}
.primary {
  margin-top: 48rpx;
  color: #fff;
  background: #18b566;
}
.secondary {
  margin-top: 18rpx;
  color: #18b566;
  background: #eaf8f0;
}
.primary::after,
.secondary::after {
  border: 0;
}
