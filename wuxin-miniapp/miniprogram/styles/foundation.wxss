page {
  min-height: 100%;
  color: #171a1d;
  background: #f5f6f8;
}

view,
text,
image,
scroll-view,
button,
input {
  box-sizing: border-box;
}

.wuxin-page {
  min-height: 100vh;
  padding: 24rpx 32rpx 0;
  background: #f5f6f8;
}

.wuxin-section {
  margin-top: 24rpx;
}

.wuxin-card {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(23, 26, 29, 0.06);
}

.wuxin-card-flat {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
}

.wuxin-section-title {
  color: #171a1d;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 42rpx;
}

.wuxin-section-subtitle {
  margin-top: 6rpx;
  color: #969ba1;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 32rpx;
}

.wuxin-divider {
  height: 1rpx;
  background: #eceef1;
}

.wuxin-reset-button {
  margin: 0;
  padding: 0;
  line-height: normal;
  background: transparent;
}

.wuxin-reset-button::after {
  border: none;
}

.wuxin-primary-button {
  color: #ffffff;
  background: #16a76a;
  border-radius: 24rpx;
  text-align: center;
}

.wuxin-primary-button:active {
  background: #128858;
}

.wuxin-disabled-button {
  color: #969ba1;
  background: #eceef1;
}

.wuxin-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  color: #5e6369;
  background: transparent;
}
