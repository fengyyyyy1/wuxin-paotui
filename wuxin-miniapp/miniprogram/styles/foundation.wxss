page {
  min-height: 100%;
  color: #111111;
  background: #f6f7f9;
}

view,
text,
image,
scroll-view,
button,
input,
textarea,
swiper,
swiper-item {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: normal;
  background: transparent;
  border-radius: 0;
}

button::after {
  border: 0;
}

.wuxin-page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #f6f7f9;
}

.wuxin-section {
  margin-top: 24rpx;
}

.wuxin-card {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.wuxin-card-flat {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 32rpx;
}

.wuxin-section-title {
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 42rpx;
}

.wuxin-section-subtitle {
  margin-top: 6rpx;
  color: #999999;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 32rpx;
}

.wuxin-divider {
  height: 1rpx;
  background: #eeeeee;
}

.wuxin-reset-button {
  margin: 0;
  padding: 0;
  line-height: normal;
  background: transparent;
}

.wuxin-reset-button::after {
  border: none;
}

.wuxin-primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 0 36rpx;
  color: #ffffff;
  background: #18b566;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: opacity 160ms ease, transform 160ms ease;
}

.wuxin-primary-button:active {
  background: #119653;
  transform: scale(0.98);
}

.wuxin-disabled-button {
  color: #999999;
  background: #eeeeee;
}

.wuxin-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  color: #666666;
  background: transparent;
}

.wuxin-page-title {
  margin: 12rpx 0 28rpx;
  color: #111111;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.wuxin-page-subtitle {
  margin-top: -16rpx;
  margin-bottom: 28rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.6;
}

.wuxin-secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 32rpx;
  color: #18b566;
  background: #eaf8f0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.wuxin-danger-button {
  color: #ff4d4f;
  background: #fff1f1;
}

.wuxin-safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.wuxin-pressable {
  transition: opacity 160ms ease, transform 160ms ease;
}

.wuxin-pressable:active {
  opacity: 0.78;
  transform: scale(0.985);
}
