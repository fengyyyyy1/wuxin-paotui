<view class="store-card" hover-class="store-card-pressed" bindtap="handleTap">
  <image class="store-image" src="{{store.imageUrl}}" mode="aspectFill" binderror="handleImageError" />
  <view class="store-content">
    <view class="store-title-row">
      <text class="store-name">{{store.storeName}}</text>
      <text class="store-status {{store.businessStatus === 1 ? 'is-open' : ''}}">{{store.statusText}}</text>
    </view>
    <text class="store-description">{{store.storeDescription || '品质商品，安心送达'}}</text>
    <view class="store-meta">
      <text>{{store.timeText || '营业时间待补充'}}</text>
      <text class="dot">·</text>
      <text class="address">{{store.addressText || '地址待补充'}}</text>
    </view>
  </view>
</view>
