<view class="stepper {{disabled ? 'is-disabled' : ''}}">
  <button class="stepper-button" disabled="{{disabled || loading || value <= min}}" bindtap="decrease">−</button>
  <text class="stepper-value">{{loading ? '·' : value}}</text>
  <button class="stepper-button stepper-plus" disabled="{{disabled || loading || value >= max}}" bindtap="increase">＋</button>
</view>
