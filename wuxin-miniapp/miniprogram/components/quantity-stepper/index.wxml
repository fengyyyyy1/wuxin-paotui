<view class="stepper {{disabled ? 'is-disabled' : ''}}">
  <view class="stepper-button {{disabled || loading || value <= min ? 'stepper-button-disabled' : ''}}" bindtap="decrease">−</view>
  <text class="stepper-value">{{loading ? '·' : value}}</text>
  <view class="stepper-button stepper-plus {{disabled || loading || value >= max ? 'stepper-plus-disabled' : ''}}" bindtap="increase">＋</view>
</view>
