<view class="section-header">
  <view class="section-copy">
    <text class="section-title">{{title}}</text>
    <text wx:if="{{subtitle}}" class="section-subtitle">{{subtitle}}</text>
  </view>
  <view wx:if="{{actionText}}" class="section-action" hover-class="section-action-pressed" bindtap="handleAction">{{actionText}} ›</view>
</view>
