<view class="section-header">
  <view class="section-copy">
    <text class="section-title">{{title}}</text>
    <text wx:if="{{subtitle}}" class="section-subtitle">{{subtitle}}</text>
  </view>
  <button wx:if="{{actionText}}" class="section-action" bindtap="handleAction">{{actionText}} ›</button>
</view>
