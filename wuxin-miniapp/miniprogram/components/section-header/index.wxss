.section-header { display:flex; align-items:flex-end; justify-content:space-between; gap:24rpx; margin-bottom:20rpx; }
.section-copy { flex:1; min-width:0; }
.section-title { display:block; color:#111111; font-size:34rpx; font-weight:700; line-height:1.3; }
.section-subtitle { display:block; margin-top:6rpx; color:#999999; font-size:22rpx; line-height:1.4; }
.section-action { flex-shrink:0; padding:8rpx 0; color:#18b566; background:transparent; font-size:24rpx; }
.section-action::after { border:0; }
