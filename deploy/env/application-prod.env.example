# 五鑫跑腿生产环境变量示例
# 仅保留变量名称和安全占位值，禁止提交真实密码、密钥、证书、商户号或私钥。

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
LOG_PATH=/var/log/wuxin-paotui

DB_URL=jdbc:mysql://mysql.internal:3306/wuxin_paotui?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=wuxin_app
DB_PASSWORD=replace-with-strong-database-password

JWT_SECRET=replace-with-at-least-32-random-characters

WECHAT_MINI_PROGRAM_ENABLED=true
WECHAT_MINI_PROGRAM_APP_ID=replace-with-mini-program-app-id
WECHAT_MINI_PROGRAM_APP_SECRET=replace-with-mini-program-app-secret
MOCK_WECHAT_LOGIN_ENABLED=false
MOCK_WECHAT_PHONE_ENABLED=false

WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=replace-with-mini-program-app-id
WECHAT_PAY_MCH_ID=replace-with-merchant-id
WECHAT_PAY_MERCHANT_SERIAL_NUMBER=replace-with-merchant-serial-number
WECHAT_PAY_PRIVATE_KEY_PATH=/secure/wxpay/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=replace-with-api-v3-key
WECHAT_PAY_NOTIFY_URL=https://api.待配置域名/api/payment/wechat/notify
MOCK_PAYMENT_ENABLED=false

OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_PROVIDER=COS
OBJECT_STORAGE_REGION=replace-with-region
OBJECT_STORAGE_BUCKET=replace-with-bucket
OBJECT_STORAGE_SECRET_ID=replace-with-secret-id
OBJECT_STORAGE_SECRET_KEY=replace-with-secret-key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.待配置域名

PUBLIC_API_DOMAIN=https://api.待配置域名
ADMIN_WEB_DOMAIN=https://admin.待配置域名
MINIAPP_REQUEST_DOMAIN=https://api.待配置域名
