.card { width: 100%; padding: 28rpx; border: 1rpx solid rgba(15, 61, 38, 0.05); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow); }
.card + .card { margin-top: 20rpx; }
.row { display: flex; align-items: center; min-width: 0; }
.row--between { justify-content: space-between; }
.row__body { flex: 1; min-width: 0; }
.button { display: flex; align-items: center; justify-content: center; min-height: 92rpx; padding: 0 32rpx; border-radius: 24rpx; background: var(--brand); color: #fff; font-size: 30rpx; font-weight: 650; line-height: 1; }
.button[disabled] { background: #cdd5d1; color: #fff; }
.button--secondary { background: var(--brand-soft); color: var(--brand-dark); }
.button--ghost { background: transparent; color: var(--text-secondary); border: 1rpx solid var(--line); }
.button--danger { background: #fff1f1; color: var(--danger); }
.field { margin-top: 20rpx; }
.field__label { display: block; margin: 0 0 10rpx 4rpx; color: var(--text-secondary); font-size: 26rpx; }
.field__input, .field__textarea { width: 100%; min-width: 0; padding: 24rpx; border: 1rpx solid var(--line); border-radius: 20rpx; background: #fff; color: var(--text); }
.field__textarea { min-height: 150rpx; }
.badge { display: inline-flex; align-items: center; min-height: 44rpx; padding: 0 16rpx; border-radius: 999rpx; background: var(--brand-soft); color: var(--brand-dark); font-size: 23rpx; white-space: nowrap; }
.badge--orange { background: #fff4e5; color: #b96500; }
.badge--red { background: #fff0f0; color: var(--danger); }
.metric-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.metric { min-width: 0; padding: 24rpx; border-radius: 24rpx; background: #fff; box-shadow: var(--shadow); }
.metric__value { font-size: 42rpx; font-weight: 720; white-space: nowrap; }
.metric__label { margin-top: 8rpx; color: var(--text-muted); font-size: 24rpx; }
.menu { overflow: hidden; padding: 0 28rpx; border-radius: var(--radius); background: #fff; box-shadow: var(--shadow); }
.menu__item { display: flex; align-items: center; width: 100%; min-height: 104rpx; border-bottom: 1rpx solid var(--line); }
.menu__item:last-child { border-bottom: 0; }
.menu__body { flex: 1; min-width: 0; }
.menu__title { font-weight: 600; }
.menu__desc { margin-top: 5rpx; color: var(--text-muted); font-size: 24rpx; }
.menu__arrow { flex-shrink: 0; margin-left: 18rpx; color: #a7afab; font-size: 34rpx; }
.empty-note { padding: 72rpx 24rpx; text-align: center; color: var(--text-muted); }
