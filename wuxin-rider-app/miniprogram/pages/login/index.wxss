.login-page { min-height: 100vh; padding: calc(150rpx + env(safe-area-inset-top)) 32rpx 48rpx; background: linear-gradient(180deg, #eaf8f1 0, #f5f7f6 48%, #f5f7f6 100%); }
.brand { margin: 0 12rpx 70rpx; }
.brand__mark { display: flex; align-items: center; justify-content: center; width: 108rpx; height: 108rpx; margin-bottom: 28rpx; border-radius: 30rpx; background: #18a660; color: #fff; font-size: 34rpx; font-weight: 750; box-shadow: 0 18rpx 40rpx rgba(24, 166, 96, .25); }
.login-card { padding: 36rpx; }
.submit { margin-top: 36rpx; }
.wechat { margin-top: 18rpx; }
.login-note { margin-top: 28rpx; color: #929b96; text-align: center; font-size: 24rpx; }
