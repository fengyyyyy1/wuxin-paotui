.detail-page { padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }
.status-hero { padding: 36rpx; border-radius: 32rpx; background: #102d20; color: #fff; }
.status-hero__title { margin-top: 24rpx; font-size: 42rpx; font-weight: 720; }
.status-hero__no { margin-top: 10rpx; color: rgba(255,255,255,.6); font-size: 23rpx; }
.route-card { margin-top: 20rpx; }
.address-block { display: flex; align-items: flex-start; min-width: 0; }
.address-block__mark { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; margin-right: 18rpx; border-radius: 17rpx; color: #fff; font-weight: 700; }
.pickup { background: var(--accent); }.delivery { background: var(--brand); }
.address-block__body { flex: 1; min-width: 0; }
.address-block__name { font-weight: 650; }.address-block__address { margin-top: 8rpx; color: var(--text-secondary); line-height: 1.5; }
.address-actions { display: flex; margin-top: 14rpx; color: var(--brand-dark); font-size: 24rpx; }.address-actions text { margin-right: 32rpx; }
.route-line { width: 2rpx; height: 34rpx; margin: 8rpx 0 8rpx 25rpx; background: var(--line); }
.section-card-title { margin-bottom: 20rpx; font-size: 30rpx; font-weight: 680; }
.goods-card,.info-card,.timeline-card { margin-top: 20rpx; }.goods-name { font-weight: 620; line-height: 1.5; }.goods-desc,.remark { margin-top: 10rpx; color: var(--text-secondary); }
.item { display: flex; gap: 18rpx; margin-top: 16rpx; color: var(--text-secondary); }.item__name { flex: 1; min-width: 0; }
.info-row { display: flex; justify-content: space-between; gap: 24rpx; padding: 17rpx 0; border-bottom: 1rpx solid var(--line); }.info-row:last-child { border-bottom: 0; }.info-row text:last-child { text-align: right; }.amount { color: var(--danger); font-weight: 700; }
.timeline { display: flex; align-items: flex-start; min-width: 0; padding: 15rpx 0; }.timeline__dot { flex-shrink: 0; width: 16rpx; height: 16rpx; margin: 12rpx 20rpx 0 0; border-radius: 50%; background: var(--brand); }.timeline__body { flex: 1; min-width: 0; line-height: 1.55; }.timeline__body .muted { font-size: 23rpx; }
.action-bar { position: fixed; left: 0; right: 0; bottom: 0; z-index: 10; display: flex; gap: 18rpx; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,.96); box-shadow: 0 -8rpx 30rpx rgba(0,0,0,.06); }.action-secondary { flex: 0 0 220rpx; }.action-primary { flex: 1; min-width: 0; }
