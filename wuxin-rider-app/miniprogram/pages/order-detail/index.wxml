<view class="page detail-page">
  <page-state wx:if="{{loading}}" type="loading" title="正在加载订单详情" />
  <page-state wx:elif="{{error}}" type="error" title="订单加载失败" description="{{error}}" action-text="重新加载" bind:action="load" />
  <block wx:elif="{{order}}">
    <view class="status-hero"><text class="badge">{{order.orderTypeText}}</text><view class="status-hero__title">{{order.statusText}}</view><view class="status-hero__no">{{order.orderNo}}</view></view>
    <view class="card route-card">
      <view class="address-block"><view class="address-block__mark pickup">取</view><view class="address-block__body"><view class="address-block__name">{{order.pickupName || order.storeName || '取货地址'}}</view><view class="address-block__address">{{order.pickupAddress || '地址待确认'}}</view><view class="address-actions"><text bindtap="callPickup">拨号</text><text bindtap="copyPickup">复制</text><text bindtap="mapPickup">地图</text></view></view></view>
      <view class="route-line"></view>
      <view class="address-block"><view class="address-block__mark delivery">送</view><view class="address-block__body"><view class="address-block__name">{{order.deliveryName || '收件人'}} {{order.deliveryPhone || ''}}</view><view class="address-block__address">{{order.deliveryAddress || '地址待确认'}}</view><view class="address-actions"><text bindtap="callDelivery">拨号</text><text bindtap="copyDelivery">复制</text><text bindtap="mapDelivery">地图</text></view></view></view>
    </view>
    <view class="card goods-card"><view class="section-card-title">订单内容</view><view class="goods-name">{{order.goodsSummary || order.goodsName || '配送订单'}}</view><view wx:if="{{order.goodsDescription}}" class="goods-desc">{{order.goodsDescription}}</view><view wx:for="{{order.items}}" wx:key="productId" class="item"><text class="item__name">{{item.productName}}</text><text>x{{item.quantity}}</text><text>¥{{item.subtotal}}</text></view><view wx:if="{{order.remark}}" class="remark">备注：{{order.remark}}</view></view>
    <view class="card info-card"><view class="info-row"><text>配送金额</text><text class="amount">¥{{amountText}}</text></view><view class="info-row"><text>支付状态</text><text>{{order.payStatusText}}</text></view><view class="info-row"><text>距离 / 重量</text><text>{{order.distance == null ? '--' : order.distance + ' km'}} / {{order.weight == null ? '--' : order.weight + ' kg'}}</text></view><view class="info-row"><text>创建时间</text><text>{{createText}}</text></view><view class="info-row"><text>支付时间</text><text>{{payText}}</text></view><view class="info-row"><text>接单时间</text><text>{{acceptText}}</text></view><view class="info-row"><text>完成配送</text><text>{{finishText}}</text></view></view>
    <view class="card timeline-card"><view class="section-card-title">状态轨迹</view><view wx:if="{{!order.timeline.length}}" class="muted">暂无状态日志</view><view wx:for="{{order.timeline}}" wx:key="createTime" class="timeline"><view class="timeline__dot"></view><view class="timeline__body"><view>{{item.remark || item.newStatusText}}</view><view class="muted">{{item.createTime}}</view></view></view></view>
    <view wx:if="{{canOperate}}" class="action-bar"><button class="button button--danger action-secondary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onGiveUp">放弃订单</button><button class="button action-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onFinish">完成配送</button></view>
  </block>
</view>
