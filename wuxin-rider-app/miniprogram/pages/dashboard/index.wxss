.hero { padding: 36rpx; border-radius: 34rpx; background: linear-gradient(145deg, #0d7441, #18a660); color: #fff; box-shadow: 0 18rpx 42rpx rgba(24,166,96,.22); }
.hero__eyebrow { color: rgba(255,255,255,.72); font-size: 24rpx; }
.hero__title { margin-top: 8rpx; font-size: 40rpx; font-weight: 720; }
.hero__note { margin-top: 26rpx; color: rgba(255,255,255,.72); font-size: 22rpx; }
.availability { flex-shrink: 0; margin-left: 20rpx; text-align: right; font-size: 22rpx; }
.availability switch { display: block; margin: 10rpx 0 0 auto; transform: scale(.82); transform-origin: right center; }
.metrics { margin-top: 22rpx; }
