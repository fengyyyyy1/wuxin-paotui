.paused { margin-bottom: 18rpx; padding: 18rpx 22rpx; border-radius: 18rpx; background: #fff4e5; color: #9c5a00; font-size: 24rpx; }
.order-card__time { flex-shrink: 0; color: var(--text-muted); font-size: 23rpx; }
.order-card__goods { margin: 24rpx 0; font-size: 32rpx; font-weight: 680; line-height: 1.45; }
.route { display: flex; align-items: flex-start; min-width: 0; margin-top: 16rpx; }
.route__point { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 44rpx; height: 44rpx; margin-right: 16rpx; border-radius: 14rpx; background: #fff4e5; color: #bd6b00; font-size: 22rpx; font-weight: 700; }
.route__point--delivery { background: var(--brand-soft); color: var(--brand-dark); }
.route__text { flex: 1; min-width: 0; line-height: 1.55; }
.order-card__footer { display: flex; align-items: center; gap: 20rpx; margin-top: 26rpx; padding-top: 24rpx; border-top: 1rpx solid var(--line); }
.price { display: block; color: var(--danger); font-size: 36rpx; font-weight: 720; white-space: nowrap; }
.meta { display: block; margin-top: 6rpx; color: var(--text-muted); font-size: 23rpx; }
.accept { flex-shrink: 0; min-width: 190rpx; min-height: 76rpx; margin: 0; border: 0; border-radius: 22rpx; background: var(--brand); color: #fff; font-size: 27rpx; line-height: 76rpx; }
.accept[disabled] { background: #ccd4d0; }
.list-note { padding: 32rpx; color: var(--text-muted); text-align: center; font-size: 24rpx; }
