<view class="page review-page">
  <view wx:if="{{loading}}" class="empty-note">正在核验骑手资质...</view>
  <block wx:elif="{{profile}}">
    <view class="status-card status-card--{{profile.auditStatus}}">
      <view class="status-card__dot"></view>
      <view class="title">{{profile.riderStatus === 2 ? '骑手账号已禁用' : profile.auditStatusText}}</view>
      <view class="subtitle">{{profile.riderStatus === 2 ? '当前账号暂不可接单，请联系平台处理。' : profile.auditStatus === 0 ? '平台正在审核你的实名资料，请耐心等待。' : profile.auditStatus === 2 ? '本次申请未通过，可修改资料后重新提交。' : '资质状态正在同步。'}}</view>
    </view>
    <view class="card detail-card">
      <view class="detail-row"><text>姓名</text><text>{{profile.realName}}</text></view>
      <view class="detail-row"><text>手机号</text><text>{{profile.phone || '未绑定'}}</text></view>
      <view class="detail-row"><text>身份证</text><text>{{profile.idCardMasked}}</text></view>
      <view class="detail-row"><text>申请时间</text><text>{{applyTime}}</text></view>
      <view wx:if="{{profile.rejectReason}}" class="reason"><text class="reason__label">平台说明</text><text>{{profile.rejectReason}}</text></view>
    </view>
    <button wx:if="{{canReapply}}" class="button action" bindtap="onReapply">修改资料并重新申请</button>
    <button class="button button--ghost action" bindtap="load">刷新状态</button>
    <button class="logout" bindtap="onLogout">退出当前账号</button>
  </block>
</view>
