<view class="page apply-page">
  <view class="card intro"><view class="title">骑手实名申请</view><view class="subtitle">资料仅用于平台资质审核，请填写真实有效的信息。</view></view>
  <view class="card form-card">
    <view class="field"><text class="field__label">手机号</text><view class="phone-row"><text>{{phone || '未绑定'}}</text><button class="phone-button" open-type="getPhoneNumber" loading="{{binding}}" bindgetphonenumber="onBindPhone">{{phone ? '重新授权' : '微信授权'}}</button></view></view>
    <view class="field"><text class="field__label">真实姓名</text><input class="field__input" data-field="realName" value="{{realName}}" maxlength="50" placeholder="请输入身份证姓名" bindinput="onInput" /></view>
    <view class="field"><text class="field__label">身份证号</text><input class="field__input" data-field="idCard" value="{{idCard}}" maxlength="18" placeholder="请输入18位身份证号" bindinput="onInput" /></view>
    <view class="field"><text class="field__label">身份证正面图片 URL</text><input class="field__input" data-field="idCardFront" value="{{idCardFront}}" maxlength="255" placeholder="当前阶段填写 HTTPS 图片地址" bindinput="onInput" /></view>
    <view class="field"><text class="field__label">身份证反面图片 URL</text><input class="field__input" data-field="idCardBack" value="{{idCardBack}}" maxlength="255" placeholder="当前阶段填写 HTTPS 图片地址" bindinput="onInput" /></view>
  </view>
  <button class="button apply-submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSubmit">提交审核</button>
</view>
