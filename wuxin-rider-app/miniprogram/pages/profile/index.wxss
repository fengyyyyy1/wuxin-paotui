.profile-card { display: flex; align-items: center; min-width: 0; padding: 34rpx; border-radius: 34rpx; background: #102d20; color: #fff; box-shadow: var(--shadow); }.profile-card__avatar { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 104rpx; height: 104rpx; margin-right: 22rpx; border-radius: 30rpx; background: var(--brand); font-size: 38rpx; font-weight: 720; }.profile-card__body { flex: 1; min-width: 0; }.profile-card__name { overflow: hidden; font-size: 36rpx; font-weight: 720; text-overflow: ellipsis; white-space: nowrap; }.profile-card__phone { margin-top: 8rpx; color: rgba(255,255,255,.65); }.profile-card__status { flex-shrink: 0; margin-left: 16rpx; text-align: right; }.profile-card__status text { display: block; margin-top: 8rpx; color: #8be0b5; font-size: 22rpx; }.logout { width: 100%; margin-top: 30rpx; border: 0; border-radius: 24rpx; background: #fff; color: var(--danger); font-size: 28rpx; }
