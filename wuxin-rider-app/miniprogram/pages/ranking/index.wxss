.ranking-page { min-height: 100vh; background: var(--page); }.tabs { display: flex; gap: 12rpx; padding: 18rpx 24rpx; background: #fff; }.tab { flex: 1; min-width: 0; padding: 16rpx 0; border-radius: 18rpx; color: var(--text-secondary); text-align: center; }.tab--active { background: var(--brand); color: #fff; }.ranking-content { padding-top: 20rpx; }
.my-rank { display: flex; align-items: center; justify-content: space-between; padding: 28rpx; border-radius: 26rpx; background: #102d20; color: rgba(255,255,255,.75); }.my-rank__value { color: #fff; font-size: 38rpx; font-weight: 720; }
.rank-list { margin-top: 20rpx; overflow: hidden; border-radius: var(--radius); background: #fff; box-shadow: var(--shadow); }.rank { display: flex; align-items: center; min-width: 0; padding: 24rpx; border-bottom: 1rpx solid var(--line); }.rank--mine { background: var(--brand-soft); }.rank__number { flex-shrink: 0; width: 54rpx; color: var(--text-muted); font-size: 30rpx; font-weight: 700; }.rank__avatar { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; margin-right: 18rpx; border-radius: 24rpx; background: #dff4e9; color: var(--brand-dark); font-weight: 700; }.rank__body { flex: 1; min-width: 0; }.rank__name { overflow: hidden; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }.rank__body .muted { margin-top: 6rpx; font-size: 23rpx; }.rank__count { flex-shrink: 0; color: var(--brand-dark); font-size: 34rpx; font-weight: 720; }.rank__count text { font-size: 22rpx; }
