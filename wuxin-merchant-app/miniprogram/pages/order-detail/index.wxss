.detail-page { padding-bottom: calc(190rpx + env(safe-area-inset-bottom)); }.status-hero { padding: 36rpx; border-radius: 32rpx; background: #102d20; color: #fff; }.status-hero__title { margin-top: 24rpx; font-size: 42rpx; font-weight: 720; }.status-hero__no { margin-top: 10rpx; color: rgba(255,255,255,.6); font-size: 23rpx; }.customer-card,.goods-card,.info-card,.timeline-card { margin-top: 20rpx; }.section-card-title { margin-bottom: 20rpx; font-size: 30rpx; font-weight: 680; }.customer-name { font-weight: 650; }.customer-name text { margin-left: 12rpx; color: var(--text-secondary); }.customer-address,.remark { margin-top: 10rpx; color: var(--text-secondary); line-height: 1.55; }.remark { padding: 18rpx; border-radius: 16rpx; background: #fff8ed; }.goods-item { display: flex; align-items: center; min-width: 0; padding: 16rpx 0; border-bottom: 1rpx solid var(--line); }.goods-item__body { flex: 1; min-width: 0; }.goods-item__name { overflow: hidden; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }.goods-item__body .muted { margin-top: 7rpx; font-size: 23rpx; }.goods-item__subtotal { flex-shrink: 0; margin-left: 18rpx; font-weight: 650; }.price-row,.info-row { display: flex; justify-content: space-between; gap: 20rpx; padding: 14rpx 0; }.price-row.total { margin-top: 10rpx; padding-top: 22rpx; border-top: 1rpx solid var(--line); font-size: 32rpx; font-weight: 700; }.price-row.total text:last-child { color: var(--danger); }.info-row text:last-child { color: var(--text-secondary); text-align: right; }.reject-note { margin-top: 18rpx; padding: 20rpx; border-radius: 18rpx; background: #fff0f0; color: var(--danger); line-height: 1.55; }.reject-note view { margin-top: 6rpx; font-size: 23rpx; }.timeline { display: flex; align-items: flex-start; padding: 14rpx 0; }.timeline__dot { flex-shrink: 0; width: 16rpx; height: 16rpx; margin: 12rpx 20rpx 0 0; border-radius: 50%; background: var(--brand); }.timeline__body { flex: 1; min-width: 0; line-height: 1.5; }.timeline__body .muted { font-size: 23rpx; }.reject-box { margin-top: 20rpx; }.reject-box__input { width: 100%; min-height: 130rpx; padding: 22rpx; border: 1rpx solid #ffd6d6; border-radius: 22rpx; background: #fff; }.action-bar { position: fixed; left: 0; right: 0; bottom: 0; z-index: 10; display: flex; gap: 18rpx; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,.96); box-shadow: 0 -8rpx 30rpx rgba(0,0,0,.06); }.action-secondary { flex: 0 0 220rpx; }.action-primary { flex: 1; min-width: 0; }
