<view class="page detail-page"><page-state wx:if="{{loading}}" type="loading" title="正在加载订单详情" /><page-state wx:elif="{{error}}" type="error" title="订单加载失败" description="{{error}}" action-text="重新加载" bind:action="load" /><block wx:elif="{{order}}"><view class="status-hero"><text class="badge {{order.status === 8 ? 'badge--red' : ''}}">{{order.payStatusName}}</text><view class="status-hero__title">{{order.statusName}}</view><view class="status-hero__no">{{order.orderNo}}</view></view>
<view class="card customer-card"><view class="section-card-title">收货信息</view><view class="customer-name">{{order.receiverName || '收件人'}} <text>{{order.receiverPhone || ''}}</text></view><view class="customer-address">{{order.deliveryAddress || '地址待确认'}}</view><view wx:if="{{order.remark}}" class="remark">用户备注：{{order.remark}}</view></view>
<view class="card goods-card"><view class="section-card-title">商品明细</view><view wx:for="{{order.items}}" wx:key="productId" class="goods-item"><view class="goods-item__body"><view class="goods-item__name">{{item.productName}}</view><view class="muted">¥{{item.productPrice}} × {{item.quantity}}</view></view><text class="goods-item__subtotal">¥{{item.subtotal}}</text></view><view class="price-row"><text>商品金额</text><text>¥{{order.productAmount}}</text></view><view class="price-row"><text>配送费</text><text>¥{{order.deliveryFee}}</text></view><view class="price-row total"><text>订单合计</text><text>¥{{totalText}}</text></view></view>
<view class="card info-card"><view class="section-card-title">订单时间</view><view class="info-row"><text>创建</text><text>{{createText}}</text></view><view class="info-row"><text>支付</text><text>{{payText}}</text></view><view class="info-row"><text>商家接单</text><text>{{acceptText}}</text></view><view class="info-row"><text>出餐</text><text>{{readyText}}</text></view><view wx:if="{{order.merchantRejectTime}}" class="info-row"><text>拒单</text><text>{{rejectText}}</text></view><view wx:if="{{order.merchantRejectReason}}" class="reject-note">拒单原因：{{order.merchantRejectReason}}<view>当前状态为待退款，不代表退款已完成。</view></view></view>
<view class="card timeline-card"><view class="section-card-title">状态轨迹</view><view wx:for="{{order.timeline}}" wx:key="createTime" class="timeline"><view class="timeline__dot"></view><view class="timeline__body"><view>{{item.remark || item.newStatusName}}</view><view class="muted">{{item.createTime}}</view></view></view></view>
<view wx:if="{{canAccept}}" class="reject-box"><textarea class="reject-box__input" value="{{rejectReason}}" maxlength="200" placeholder="拒单时必须填写2到200字原因" bindinput="onReason" /></view><view wx:if="{{canAccept || canReady}}" class="action-bar"><button wx:if="{{canAccept}}" class="button button--danger action-secondary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onReject">拒绝订单</button><button wx:if="{{canReady}}" class="button action-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onReady">确认出餐</button><button wx:else class="button action-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onAccept">接受订单</button></view></block></view>
