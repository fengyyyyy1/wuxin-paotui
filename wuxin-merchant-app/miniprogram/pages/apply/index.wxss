.apply-page { padding-bottom: calc(140rpx + env(safe-area-inset-bottom)); }.intro { background: linear-gradient(145deg, #0f7e48, #18a660); color: #fff; }.intro .subtitle { color: rgba(255,255,255,.78); }.address-grid,.time-row { display: flex; gap: 14rpx; margin-top: 20rpx; }.address-grid .field__input,.time-row picker { flex: 1; min-width: 0; }.time-picker { padding: 24rpx; border: 1rpx solid var(--line); border-radius: 20rpx; background: #fff; text-align: center; }.apply-submit { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(20rpx + env(safe-area-inset-bottom)); z-index: 5; }
