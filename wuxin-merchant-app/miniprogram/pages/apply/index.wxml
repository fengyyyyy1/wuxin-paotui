<view class="page apply-page"><view class="card intro"><view class="title">商家入驻</view><view class="subtitle">提交主体与门店资料，审核通过后即可管理商品和订单。</view></view>
<view class="section-title">主体资料</view><view class="card form-card"><view class="field"><text class="field__label">商家主体名称 *</text><input class="field__input" data-field="merchantName" value="{{merchantName}}" maxlength="100" bindinput="onInput" /></view><view class="field"><text class="field__label">联系人 *</text><input class="field__input" data-field="contactName" value="{{contactName}}" maxlength="50" bindinput="onInput" /></view><view class="field"><text class="field__label">联系电话 *</text><input class="field__input" data-field="contactPhone" value="{{contactPhone}}" type="number" maxlength="20" bindinput="onInput" /></view><view class="field"><text class="field__label">营业执照图片 URL</text><input class="field__input" data-field="businessLicense" value="{{businessLicense}}" maxlength="255" bindinput="onInput" /></view><view class="field"><text class="field__label">身份证正面 URL</text><input class="field__input" data-field="idCardFront" value="{{idCardFront}}" maxlength="255" bindinput="onInput" /></view><view class="field"><text class="field__label">身份证反面 URL</text><input class="field__input" data-field="idCardBack" value="{{idCardBack}}" maxlength="255" bindinput="onInput" /></view></view>
<view class="section-title">门店资料</view><view class="card form-card"><view class="field"><text class="field__label">店铺名称 *</text><input class="field__input" data-field="storeName" value="{{storeName}}" maxlength="100" bindinput="onInput" /></view><view class="field"><text class="field__label">店铺联系电话 *</text><input class="field__input" data-field="storePhone" value="{{storePhone}}" maxlength="20" bindinput="onInput" /></view><view class="field"><text class="field__label">店铺 Logo URL</text><input class="field__input" data-field="storeLogo" value="{{storeLogo}}" maxlength="255" bindinput="onInput" /></view><view class="field"><text class="field__label">店铺介绍</text><textarea class="field__textarea" data-field="storeDescription" value="{{storeDescription}}" maxlength="500" bindinput="onInput" /></view><view class="address-grid"><input class="field__input" data-field="province" value="{{province}}" bindinput="onInput" /><input class="field__input" data-field="city" value="{{city}}" bindinput="onInput" /><input class="field__input" data-field="district" value="{{district}}" bindinput="onInput" /></view><view class="field"><text class="field__label">详细地址 *</text><input class="field__input" data-field="detailAddress" value="{{detailAddress}}" maxlength="255" bindinput="onInput" /></view><view class="address-grid"><input class="field__input" data-field="latitude" value="{{latitude}}" type="digit" placeholder="纬度（可选）" bindinput="onInput" /><input class="field__input" data-field="longitude" value="{{longitude}}" type="digit" placeholder="经度（可选）" bindinput="onInput" /></view><view class="time-row"><picker mode="time" value="{{openTime}}" bindchange="onOpenTime"><view class="time-picker">开店 {{openTime}}</view></picker><picker mode="time" value="{{closeTime}}" bindchange="onCloseTime"><view class="time-picker">打烊 {{closeTime}}</view></picker></view></view>
<button class="button apply-submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSubmit">提交入驻申请</button></view>
