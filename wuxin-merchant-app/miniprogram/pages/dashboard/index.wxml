<view class="page page--tab dashboard"><view class="hero"><view class="hero__eyebrow">商家工作台</view><view class="row row--between"><view class="hero__title">{{storeName}}</view><text class="business {{businessOpen ? 'business--open' : ''}}">{{businessText}}</text></view><view class="hero__summary">今日 {{todayOrders}} 单 · 已完成 {{completed}} 单</view></view>
<view class="metric-grid metrics"><view class="metric"><view class="metric__value">{{waiting}}</view><view class="metric__label">待接单</view></view><view class="metric"><view class="metric__value">{{preparing}}</view><view class="metric__label">制作中</view></view><view class="metric"><view class="metric__value">{{waitingRider}}</view><view class="metric__label">待骑手接单</view></view><view class="metric"><view class="metric__value">{{products}}</view><view class="metric__label">商品总数</view></view></view>
<view class="section-title">经营管理</view><view class="menu"><view class="menu__item" bindtap="toOrders"><view class="menu__body"><view class="menu__title">订单管理</view><view class="menu__desc">接单、拒单与出餐</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toProducts"><view class="menu__body"><view class="menu__title">商品管理</view><view class="menu__desc">商品、库存与上下架</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toCategories"><view class="menu__body"><view class="menu__title">分类管理</view><view class="menu__desc">维护店铺商品分类</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toStore"><view class="menu__body"><view class="menu__title">店铺管理</view><view class="menu__desc">资料与营业状态</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toAnalytics"><view class="menu__body"><view class="menu__title">营业数据</view><view class="menu__desc">基于真实订单数量的有限汇总</view></view><text class="menu__arrow">›</text></view></view></view>
