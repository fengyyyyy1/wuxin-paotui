.hero { padding: 36rpx; border-radius: 34rpx; background: linear-gradient(145deg, #102d20, #176d45); color: #fff; box-shadow: 0 18rpx 42rpx rgba(16,45,32,.2); }.hero__eyebrow { color: rgba(255,255,255,.62); font-size: 24rpx; }.hero__title { flex: 1; min-width: 0; margin-top: 12rpx; overflow: hidden; font-size: 40rpx; font-weight: 720; text-overflow: ellipsis; white-space: nowrap; }.hero__summary { margin-top: 24rpx; color: rgba(255,255,255,.72); }.business { flex-shrink: 0; margin: 12rpx 0 0 20rpx; padding: 10rpx 16rpx; border-radius: 999rpx; background: rgba(255,255,255,.12); color: #d2d8d5; font-size: 23rpx; }.business--open { background: rgba(79,221,147,.15); color: #75e2a9; }.metrics { margin-top: 22rpx; }
