<view class="page store-page"><view class="business-card"><view><view class="business-card__label">当前营业状态</view><view class="business-card__value">{{businessText}}</view></view><button class="business-button {{businessStatus === 1 ? 'business-button--close' : ''}}" loading="{{switching}}" disabled="{{switching}}" bindtap="onSwitchBusiness">{{businessStatus === 1 ? '暂停营业' : '开始营业'}}</button></view><view class="section-title">门店资料</view><view class="card form-card"><view class="field"><text class="field__label">店铺名称</text><input class="field__input" data-field="storeName" value="{{storeName}}" bindinput="onInput" /></view><view class="field"><text class="field__label">联系电话</text><input class="field__input" data-field="storePhone" value="{{storePhone}}" bindinput="onInput" /></view><view class="field"><text class="field__label">店铺 Logo URL</text><input class="field__input" data-field="storeLogo" value="{{storeLogo}}" bindinput="onInput" /></view><view class="field"><text class="field__label">店铺介绍</text><textarea class="field__textarea" data-field="storeDescription" value="{{storeDescription}}" maxlength="500" bindinput="onInput" /></view><view class="address-grid"><input class="field__input" data-field="province" value="{{province}}" placeholder="省" bindinput="onInput" /><input class="field__input" data-field="city" value="{{city}}" placeholder="市" bindinput="onInput" /><input class="field__input" data-field="district" value="{{district}}" placeholder="区县" bindinput="onInput" /></view><view class="field"><text class="field__label">详细地址</text><input class="field__input" data-field="detailAddress" value="{{detailAddress}}" bindinput="onInput" /></view><view class="address-grid"><input class="field__input" data-field="latitude" value="{{latitude}}" type="digit" placeholder="纬度" bindinput="onInput" /><input class="field__input" data-field="longitude" value="{{longitude}}" type="digit" placeholder="经度" bindinput="onInput" /></view><view class="time-row"><picker mode="time" value="{{openTime}}" bindchange="onOpenTime"><view class="time-picker">开店 {{openTime}}</view></picker><picker mode="time" value="{{closeTime}}" bindchange="onCloseTime"><view class="time-picker">打烊 {{closeTime}}</view></picker></view></view><button class="button save" loading="{{saving}}" disabled="{{saving}}" bindtap="onSave">保存店铺资料</button></view>
