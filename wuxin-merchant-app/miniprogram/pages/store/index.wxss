.business-card { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 32rpx; border-radius: 30rpx; background: #102d20; color: #fff; }.business-card__label { color: rgba(255,255,255,.62); font-size: 24rpx; }.business-card__value { margin-top: 8rpx; font-size: 38rpx; font-weight: 720; }.business-button { flex-shrink: 0; min-width: 180rpx; margin: 0; border: 0; border-radius: 22rpx; background: var(--brand); color: #fff; font-size: 26rpx; }.business-button--close { background: rgba(255,255,255,.12); }.address-grid,.time-row { display: flex; gap: 14rpx; margin-top: 20rpx; }.address-grid .field__input,.time-row picker { flex: 1; min-width: 0; }.time-picker { padding: 24rpx 8rpx; border: 1rpx solid var(--line); border-radius: 20rpx; text-align: center; }.save { margin-top: 22rpx; }
