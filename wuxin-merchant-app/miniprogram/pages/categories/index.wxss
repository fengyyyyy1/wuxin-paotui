.editor__title { font-weight: 680; }.editor__row { display: flex; align-items: center; gap: 12rpx; margin-top: 18rpx; }.editor__name { flex: 1; min-width: 0; height: 76rpx; padding: 0 18rpx; border-radius: 18rpx; background: var(--page); }.editor__sort { flex: 0 0 110rpx; width: 110rpx; height: 76rpx; padding: 0 14rpx; border-radius: 18rpx; background: var(--page); }.editor__save { flex-shrink: 0; width: 120rpx; height: 76rpx; margin: 0; padding: 0; border: 0; border-radius: 18rpx; background: var(--brand); color: #fff; font-size: 25rpx; line-height: 76rpx; }.editor__cancel { display: inline-block; margin-top: 16rpx; color: var(--text-muted); font-size: 24rpx; }.category-list { margin-top: 20rpx; overflow: hidden; border-radius: var(--radius); background: #fff; box-shadow: var(--shadow); }.category { display: flex; align-items: center; min-width: 0; padding: 24rpx; border-bottom: 1rpx solid var(--line); }.category__body { flex: 1; min-width: 0; }.category__name { overflow: hidden; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }.category__body .muted { margin-top: 6rpx; font-size: 23rpx; }.category__action { flex-shrink: 0; margin: 0 0 0 8rpx; padding: 10rpx 12rpx; border: 0; background: transparent; color: var(--brand-dark); font-size: 23rpx; line-height: 1.4; }.category__delete { color: var(--danger); }
