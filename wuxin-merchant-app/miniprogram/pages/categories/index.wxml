<view class="page categories-page"><view class="card editor"><view class="editor__title">{{editingId ? '编辑分类' : '新增分类'}}</view><view class="editor__row"><input class="editor__name" value="{{name}}" maxlength="50" placeholder="分类名称" bindinput="onName" /><input class="editor__sort" value="{{sort}}" type="number" placeholder="排序" bindinput="onSort" /><button class="editor__save" loading="{{submitting}}" bindtap="save">保存</button></view><text wx:if="{{editingId}}" class="editor__cancel" bindtap="cancel">取消编辑</text></view><page-state wx:if="{{loading && !items.length}}" type="loading" title="正在加载分类" /><page-state wx:elif="{{!items.length}}" title="暂无商品分类" description="先创建分类，再新增商品" /><view wx:else class="category-list"><view wx:for="{{items}}" wx:key="categoryId" class="category"><view class="category__body"><view class="category__name">{{item.categoryName}}</view><view class="muted">排序 {{item.sort || 0}} · {{item.statusText}}</view></view><button class="category__action" data-id="{{item.categoryId}}" bindtap="edit">编辑</button><button class="category__action" data-id="{{item.categoryId}}" data-status="{{item.status}}" bindtap="toggle">{{item.status === 1 ? '禁用' : '启用'}}</button><button class="category__action category__delete" data-id="{{item.categoryId}}" bindtap="remove">删除</button></view></view></view>
