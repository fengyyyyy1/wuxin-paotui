<view class="page review-page"><view wx:if="{{loading}}" class="empty-note">正在核验商家资质...</view><block wx:elif="{{profile}}"><view class="status-card status-card--{{profile.auditStatus}}"><view class="status-card__dot"></view><view class="title">{{profile.merchantStatus === 0 && profile.auditStatus === 1 ? '商家账号已禁用' : profile.auditStatusText}}</view><view class="subtitle">{{profile.auditStatus === 0 ? '平台正在审核主体与门店资料。' : profile.auditStatus === 2 ? '本次申请未通过，请联系平台补充资料。' : '当前商家或店铺暂不可经营。'}}</view></view><view class="card detail-card"><view class="detail-row"><text>商家</text><text>{{profile.merchantName}}</text></view><view class="detail-row"><text>门店</text><text>{{profile.storeName}}</text></view><view class="detail-row"><text>联系人</text><text>{{profile.contactName}} {{profile.contactPhone}}</text></view><view class="detail-row"><text>提交时间</text><text>{{applyTime}}</text></view><view wx:if="{{profile.rejectReason || profile.auditRemark}}" class="reason"><text class="reason__label">平台说明</text><text>{{profile.rejectReason || profile.auditRemark}}</text></view></view><button class="button button--ghost action" bindtap="load">刷新状态</button><button class="logout" bindtap="onLogout">退出当前账号</button></block></view>
