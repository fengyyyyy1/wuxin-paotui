<view class="orders-page"><view class="search"><input class="search__input" value="{{keyword}}" placeholder="搜索订单号或商品" confirm-type="search" bindinput="onKeyword" bindconfirm="onSearch" /><button class="search__button" bindtap="onSearch">搜索</button><text wx:if="{{keyword}}" class="search__clear" bindtap="onClear">清空</text></view><scroll-view class="tabs" scroll-x enhanced show-scrollbar="{{false}}"><view class="tabs__inner"><view wx:for="{{tabs}}" wx:key="label" class="tab {{active === index ? 'tab--active' : ''}}" data-index="{{index}}" bindtap="onTab">{{item.label}}</view></view></scroll-view><view class="page content"><page-state wx:if="{{loading && !items.length}}" type="loading" title="正在加载商家订单" /><page-state wx:elif="{{error && !items.length}}" type="error" title="加载失败" description="{{error}}" action-text="重试" bind:action="reload" /><page-state wx:elif="{{!items.length}}" title="该分类暂无订单" /><view wx:else><view wx:for="{{items}}" wx:key="orderId" class="card order" data-id="{{item.orderId}}" bindtap="toDetail"><view class="row row--between"><text class="order__no">{{item.orderNo}}</text><text class="badge {{item.status === 8 || item.status === 5 ? 'badge--red' : item.status === 0 ? 'badge--orange' : ''}}">{{item.statusName}}</text></view><view class="order__goods">{{item.goodsSummary || '商品订单'}}</view><view class="order__customer">{{item.receiverName || '收件人'}} · {{item.receiverPhone || '无手机号'}}</view><view class="order__address">{{item.deliveryAddress || '地址待确认'}}</view><view class="row row--between order__footer"><text class="muted">{{item.createText}}</text><text class="order__amount">¥{{item.amountText}}</text></view></view><view class="list-note">{{loadingMore ? '正在加载更多...' : pageNum >= pages ? '已展示全部订单' : ''}}</view></view></view></view>
