.orders-page { min-height: 100vh; background: var(--page); }.search { display: flex; align-items: center; gap: 12rpx; padding: 18rpx 24rpx 8rpx; background: #fff; }.search__input { flex: 1; min-width: 0; height: 76rpx; padding: 0 22rpx; border-radius: 20rpx; background: var(--page); }.search__button { flex-shrink: 0; width: 120rpx; height: 76rpx; margin: 0; padding: 0; border: 0; border-radius: 20rpx; background: var(--brand); color: #fff; font-size: 26rpx; line-height: 76rpx; }.search__clear { flex-shrink: 0; color: var(--text-muted); font-size: 24rpx; }.tabs { position: sticky; top: 0; z-index: 5; background: #fff; }.tabs__inner { display: flex; width: max-content; padding: 14rpx 24rpx 18rpx; }.tab { flex-shrink: 0; margin-right: 12rpx; padding: 14rpx 22rpx; border-radius: 999rpx; color: var(--text-secondary); white-space: nowrap; }.tab--active { background: var(--brand); color: #fff; }.content { padding-top: 20rpx; }.order__no { flex: 1; min-width: 0; overflow: hidden; color: var(--text-muted); font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }.order__goods { margin-top: 18rpx; font-size: 31rpx; font-weight: 650; line-height: 1.45; }.order__customer,.order__address { margin-top: 10rpx; overflow: hidden; color: var(--text-secondary); text-overflow: ellipsis; white-space: nowrap; }.order__footer { margin-top: 20rpx; padding-top: 18rpx; border-top: 1rpx solid var(--line); }.order__amount { color: var(--danger); font-size: 30rpx; font-weight: 700; }.list-note { padding: 30rpx; color: var(--text-muted); text-align: center; }
