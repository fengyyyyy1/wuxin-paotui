<view class="page edit-page"><view class="card form-card"><view class="field"><text class="field__label">商品分类</text><picker range="{{categories}}" range-key="categoryName" value="{{categoryIndex}}" bindchange="onCategory"><view class="field__input picker-value">{{categories.length ? categories[categoryIndex].categoryName : '暂无可用分类'}}</view></picker></view><view class="field"><text class="field__label">商品名称</text><input class="field__input" data-field="productName" value="{{productName}}" maxlength="100" bindinput="onInput" /></view><view class="field"><text class="field__label">商品图片 URL</text><input class="field__input" data-field="productImage" value="{{productImage}}" maxlength="255" bindinput="onInput" /></view><view class="field"><text class="field__label">商品描述</text><textarea class="field__textarea" data-field="productDescription" value="{{productDescription}}" maxlength="500" bindinput="onInput" /></view><view class="form-row"><view class="field half"><text class="field__label">销售价</text><input class="field__input" data-field="price" value="{{price}}" type="digit" placeholder="0.00" bindinput="onInput" /></view><view class="field half"><text class="field__label">原价（可选）</text><input class="field__input" data-field="originalPrice" value="{{originalPrice}}" type="digit" placeholder="0.00" bindinput="onInput" /></view></view><view class="form-row"><view class="field half"><text class="field__label">库存</text><input class="field__input" data-field="stock" value="{{stock}}" type="number" bindinput="onInput" /></view><view class="field half"><text class="field__label">排序</text><input class="field__input" data-field="sort" value="{{sort}}" type="number" bindinput="onInput" /></view></view></view><button class="button save" loading="{{saving}}" disabled="{{saving || !categories.length}}" bindtap="save">保存商品</button><view class="hint">新商品默认下架，保存后请在商品列表手动上架。</view></view>
