<view class="page page--tab profile-page"><view class="profile-card"><view class="profile-card__avatar">{{name.slice(0, 1)}}</view><view class="profile-card__body"><view class="profile-card__name">{{name}}</view><view class="profile-card__contact">{{contact}}</view></view><view class="profile-card__status"><text>{{auditText}}</text><text>{{businessText}}</text></view></view><view class="section-title">经营管理</view><view class="menu"><view class="menu__item" bindtap="toOrders"><view class="menu__body"><view class="menu__title">订单管理</view><view class="menu__desc">处理新订单与出餐</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toProducts"><view class="menu__body"><view class="menu__title">商品管理</view><view class="menu__desc">库存、价格与上下架</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toCategories"><view class="menu__body"><view class="menu__title">分类管理</view><view class="menu__desc">维护商品分类</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toStore"><view class="menu__body"><view class="menu__title">店铺信息</view><view class="menu__desc">{{businessText}} · 编辑门店资料</view></view><text class="menu__arrow">›</text></view><view class="menu__item" bindtap="toAnalytics"><view class="menu__body"><view class="menu__title">营业数据</view><view class="menu__desc">真实订单数量汇总</view></view><text class="menu__arrow">›</text></view></view><view class="section-title">平台服务</view><view class="menu"><view class="menu__item" bindtap="about"><view class="menu__body"><view class="menu__title">关于平台</view><view class="menu__desc">五鑫跑腿商家服务说明</view></view><text class="menu__arrow">›</text></view></view><button class="logout" bindtap="onLogout">退出登录</button></view>
