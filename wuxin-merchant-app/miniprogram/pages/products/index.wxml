<view class="products-page"><view class="toolbar"><input class="toolbar__input" value="{{keyword}}" placeholder="搜索商品名称" confirm-type="search" bindinput="onKeyword" bindconfirm="onSearch" /><picker range="{{statuses}}" range-key="label" value="{{statusIndex}}" bindchange="onStatus"><view class="toolbar__filter">{{statuses[statusIndex].label}}⌄</view></picker><button class="toolbar__add" bindtap="add">新增</button></view><view class="page content"><page-state wx:if="{{loading && !items.length}}" type="loading" title="正在加载商品" /><page-state wx:elif="{{error && !items.length}}" type="error" title="加载失败" description="{{error}}" action-text="重试" bind:action="reload" /><page-state wx:elif="{{!items.length}}" title="暂无商品" description="点击右上角新增商品" /><view wx:else><view wx:for="{{items}}" wx:key="productId" class="card product"><image class="product__image" src="{{item.displayImage}}" mode="aspectFill" data-index="{{index}}" binderror="onImageError" /><view class="product__body"><view class="row row--between"><view class="product__name">{{item.productName}}</view><text class="badge {{item.productStatus === 0 ? 'badge--red' : ''}}">{{item.productStatusText}}</text></view><view class="product__meta">{{item.categoryName}} · 库存 {{item.stock}} · 销量 {{item.sales}}</view><view class="product__price">¥{{item.priceText}}</view><view class="product__actions"><button data-id="{{item.productId}}" bindtap="edit">编辑</button><button data-id="{{item.productId}}" loading="{{item.updating}}" bindtap="toggle">{{item.productStatus === 1 ? '下架' : '上架'}}</button><button class="delete" data-id="{{item.productId}}" bindtap="remove">删除</button></view></view></view><view class="list-note">{{loadingMore ? '正在加载更多...' : pageNum >= pages ? '已展示全部商品' : ''}}</view></view></view></view>
