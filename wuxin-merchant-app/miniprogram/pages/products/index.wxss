.products-page { min-height: 100vh; background: var(--page); }.toolbar { display: flex; align-items: center; gap: 12rpx; padding: 18rpx 24rpx; background: #fff; }.toolbar__input { flex: 1; min-width: 0; height: 76rpx; padding: 0 20rpx; border-radius: 20rpx; background: var(--page); }.toolbar picker,.toolbar__filter,.toolbar__add { flex-shrink: 0; }.toolbar__filter { height: 76rpx; padding: 0 16rpx; border-radius: 20rpx; background: var(--page); line-height: 76rpx; white-space: nowrap; }.toolbar__add { width: 110rpx; height: 76rpx; margin: 0; padding: 0; border: 0; border-radius: 20rpx; background: var(--brand); color: #fff; font-size: 25rpx; line-height: 76rpx; }.content { padding-top: 20rpx; }.product { display: flex; align-items: flex-start; min-width: 0; }.product__image { flex-shrink: 0; width: 150rpx; height: 150rpx; margin-right: 20rpx; border-radius: 22rpx; background: var(--page); }.product__body { flex: 1; min-width: 0; }.product__name { flex: 1; min-width: 0; overflow: hidden; font-size: 30rpx; font-weight: 680; text-overflow: ellipsis; white-space: nowrap; }.product__meta { margin-top: 10rpx; overflow: hidden; color: var(--text-muted); font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }.product__price { margin-top: 12rpx; color: var(--danger); font-size: 32rpx; font-weight: 720; }.product__actions { display: flex; justify-content: flex-end; margin-top: 12rpx; }.product__actions button { margin: 0 0 0 8rpx; padding: 9rpx 13rpx; border: 0; background: transparent; color: var(--brand-dark); font-size: 23rpx; line-height: 1.4; }.product__actions .delete { color: var(--danger); }.list-note { padding: 30rpx; color: var(--text-muted); text-align: center; }
